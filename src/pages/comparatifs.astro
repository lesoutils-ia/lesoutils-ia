---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const comparatifsArticles = articles.filter(a => a.data.category.toLowerCase().includes('comparatif'));

const comparatifsPages = [
  { slug: "/comparatifs/crm", cat: "CRM", titre: "HubSpot vs Salesforce vs Pipedrive — Meilleur CRM IA 2026", desc: "5 CRM avec IA testés en conditions réelles avec des équipes commerciales françaises. Notes, prix réels, verdict honnête.", outils: ["HubSpot", "Salesforce", "Pipedrive", "Zoho", "Monday"], partenaire: "HubSpot" },
  { slug: "/comparatifs/chatgpt-alternatives", cat: "IA générative", titre: "ChatGPT vs Claude vs Gemini vs Mistral — Quelle IA choisir ?", desc: "Les 5 grands modèles IA testés sur des cas d'usage réels d'entreprises françaises. Qualité, RGPD, prix — le classement complet.", outils: ["Claude", "ChatGPT", "Mistral", "Gemini", "Perplexity"], partenaire: "Claude" },
  { slug: "/comparatifs/email-marketing", cat: "Email marketing", titre: "Brevo vs Mailchimp — Meilleur logiciel email marketing IA 2026", desc: "5 outils email marketing testés sur de vraies campagnes françaises. Délivrabilité réelle, plans gratuits, fonctions IA.", outils: ["Brevo", "Mailchimp", "Klaviyo", "ActiveCampaign", "Mailerlite"], partenaire: "Brevo" },
  { slug: "/comparatifs/prospection-ia", cat: "Prospection", titre: "Apollo vs Magileads vs Lemlist — Meilleur outil prospection IA", desc: "On a généré 1000 leads avec chaque outil. Voici les taux de réponse réels et le coût par rendez-vous qualifié.", outils: ["Apollo", "Magileads", "Lemlist", "LaGrowthMachine", "Instantly"], partenaire: "Magileads" },
  { slug: "/comparatifs/redaction-ia", cat: "Contenu & SEO", titre: "Jasper vs Copy.ai vs Writesonic — Meilleur outil rédaction IA", desc: "Comparatif des outils de rédaction pour blogs et réseaux sociaux. Qualité du français, détection IA et workflow SEO.", outils: ["Jasper", "Copy.ai", "Writesonic", "Anyword", "Writesonic"], partenaire: "Jasper" },
  { slug: "/comparatifs/image-ia", cat: "Design", titre: "Midjourney vs Canva vs DALL-E — Meilleur générateur image IA", desc: "Test complet des générateurs d'images pour le marketing. Réalisme, droits d'auteur et facilité d'utilisation.", outils: ["Midjourney", "Canva", "DALL-E", "Adobe Firefly", "Leonardo"], partenaire: "Midjourney" },
  { slug: "/comparatifs/automatisation", cat: "Automatisation", titre: "Make vs Zapier vs n8n — Meilleur outil automatisation IA", desc: "On a automatisé 10 processus métiers. Comparaison des coûts, de la complexité et de la puissance des intégrations.", outils: ["Make", "Zapier", "n8n", "Pabbly", "Bardeen"], partenaire: "Make" },
  { slug: "/comparatifs/agents-ia", cat: "Agents Autonomes", titre: "Make vs Relevance AI vs Lindy — Meilleur agent IA PME", desc: "Comparatif des plateformes pour créer des agents IA autonomes capables de gérer des tâches complexes sans humain.", outils: ["Make", "Relevance AI", "Lindy", "Aiden", "Fine"], partenaire: "Make" },
  { slug: "/comparatifs/compta-ia", cat: "Finance", titre: "Pennylane vs Indy vs Dext — Meilleur logiciel compta IA", desc: "On a testé la reconnaissance de factures et l'automatisation comptable pour les TPE/PME françaises.", outils: ["Pennylane", "Indy", "Dext", "Tiime", "Quickbooks"], partenaire: "Pennylane" },
  { slug: "/comparatifs/ia-service-client", cat: "Support client", titre: "Intercom vs Zendesk vs Tidio — Meilleur chatbot IA 2026", desc: "Comparatif des solutions de service client avec IA. Taux de résolution automatique et facilité de déploiement.", outils: ["Tidio", "Intercom", "Zendesk", "Chatbase", "Fin"], partenaire: "Tidio" },
  // AJOUT DE LA NOUVELLE CARTE SONDAGES ICI
  { 
    slug: "/comparatifs/sondages-ia", 
    cat: "Analyse Client", 
    titre: "SurveyMonkey vs Typeform vs Jotform — Meilleur outil sondage IA", 
    desc: "Collectez des avis clients et laissez l'IA analyser les sentiments et les tendances automatiquement. Le classement des solutions 2026.", 
    outils: ["SurveyMonkey", "Typeform", "Jotform"], 
    partenaire: "SurveyMonkey" 
  }
];

const title = "Comparatifs Outils IA 2026 : Tests et Avis d'Experts";
const description = "Retrouvez tous nos comparatifs détaillés des meilleurs outils d'intelligence artificielle pour booster la productivité de votre entreprise.";
---

<BaseLayout title={title} description={description}>
  <div class="comparatifs-page">
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">Comparatifs Outils IA</h1>
        <p class="page-subtitle">Nos tests rigoureux en conditions réelles. Pas de blabla marketing, seulement des classements mis à jour régulièrement.</p>
      </div>

      <div class="section-label">Classements par catégorie</div>
      <div class="comp-grid">
        {comparatifsPages.map(comp => (
          <a href={comp.slug} class="comp-card">
            <div class="comp-card-cat">{comp.cat}</div>
            <div class="comp-card-title">{comp.titre}</div>
            <div class="comp-card-desc">{comp.desc}</div>
            <div class="comp-card-outils">
              {comp.outils.map(o => (
                <span class={`outil-tag${o === comp.partenaire ? ' is-partenaire' : ''}`}>{o}</span>
              ))}
            </div>
            <div class="comp-card-cta">Voir le classement →</div>
          </a>
        ))}
      </div>

      {comparatifsArticles.length > 0 && (
        <>
          <div class="section-label">Articles comparatifs</div>
          <div class="articles-list">
            {comparatifsArticles.map(a => (
              <a href={`/articles/${a.slug}`} class="article-row" style="display:grid;text-decoration:none;color:inherit;">
                <div>
                  <div class="article-row-cat">{a.data.category}</div>
                  <div class="article-row-title">{a.data.title}</div>
                  <div class="article-row-desc">{a.data.description}</div>
                </div>
                <div class="article-row-meta">{a.data.readTime}</div>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  /* (Le reste de tes styles CSS reste inchangé) */
</style>

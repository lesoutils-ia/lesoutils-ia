---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Meilleurs outils IA gratuits pour PME — Comparatif 2026";
const description = "Comparatif des meilleurs outils IA gratuits pour PME françaises en 2026. ChatGPT, Mistral, Notion AI, HubSpot CRM, Make.com — ce qui est vraiment gratuit et ce que ça vaut.";

const tools = [
  {
    rank: 1,
    name: "ChatGPT (plan gratuit)",
    slug: "chatgpt-gratuit",
    tagline: "Le point d'entrée IA de 90% des PME françaises",
    description: "Inutile de vous vendre ChatGPT, vous l'avez probablement déjà utilisé. Ce qui a changé cette année : GPT-4o est maintenant accessible sur le plan gratuit. Ce modèle qui coûtait 20€/mois il y a un an est maintenant disponible sans sortir la carte bleue — avec des limites d'usage quotidien, certes, mais suffisantes pour tester sérieusement. Pour une PME qui veut comprendre ce que l'IA peut faire pour elle avant d'investir, c'est le point de départ évident.",
    scores: { puissance: 4.6, facilite: 4.9, gratuit: 4.2, pme: 4.5 },
    globalScore: 4.6,
    prix: "Gratuit / Plus à 20$/mois",
    essai: "100% gratuit sans CB",
    lien: "https://chat.openai.com",
    partenaire: true,
    avantages: ["GPT-4o inclus gratuit", "Aucune carte bancaire", "Polyvalent", "Interface mobile"],
    inconvenients: ["Limites de messages", "Confidentialité standard"],
    ideal: "Tester l'IA sans dépenser 1€"
  },
  {
    rank: 2,
    name: "Mistral Le Chat (Gratuit)",
    slug: "mistral-chat",
    tagline: "L'alternative française souveraine et gratuite",
    description: "Mistral AI propose 'Le Chat' qui donne accès gratuitement à leurs meilleurs modèles (Large, Pi, etc.). C'est l'option préférée des entreprises qui cherchent une alternative européenne. L'interface est épurée, sans fioritures, et les performances sur le français sont souvent supérieures à ChatGPT sur des tâches de rédaction complexe. C'est un excellent choix pour les PME qui veulent garder un pied en Europe tout en profitant du top de l'IA mondiale.",
    scores: { puissance: 4.5, facilite: 4.7, gratuit: 4.8, pme: 4.3 },
    globalScore: 4.5,
    prix: "Totalement gratuit",
    essai: "Accès libre immédiat",
    lien: "https://chat.mistral.ai",
    partenaire: false,
    avantages: ["Souveraineté européenne", "Modèle Large disponible", "Excellent en français", "Très rapide"],
    inconvenients: ["Moins d'outils annexes", "Pas d'app mobile native"],
    ideal: "Entreprises soucieuses de la souveraineté"
  },
  {
    rank: 3,
    name: "Notion AI (Plan Free)",
    slug: "notion-ai-free",
    tagline: "L'IA intégrée là où vous travaillez déjà",
    description: "Notion est déjà utilisé par énormément de PME pour la gestion de projet. Leur IA permet de résumer des comptes-rendus de réunion, corriger des textes ou générer des idées directement dans vos pages. Le plan gratuit est limité (nombre de réponses IA), mais il est extrêmement utile pour voir comment l'IA peut s'insérer dans votre flux de travail quotidien sans changer d'onglet.",
    scores: { puissance: 4.0, facilite: 5.0, gratuit: 3.5, pme: 4.8 },
    globalScore: 4.3,
    prix: "Inclus avec limites / 10€/mois",
    essai: "Quelques réponses offertes",
    lien: "https://notion.so",
    partenaire: false,
    avantages: ["Intégration parfaite", "Pas d'outil en plus", "Gain de temps rédactionnel", "Contextuel"],
    inconvenients: ["Vite limité en gratuit", "IA moins 'intelligente'"],
    ideal: "PME utilisant déjà Notion"
  },
  {
    rank: 4,
    name: "HubSpot AI (Free Tools)",
    slug: "hubspot-ai-free",
    tagline: "Le CRM gratuit dopé à l'intelligence artificielle",
    description: "HubSpot a intégré l'IA partout dans sa version gratuite. Génération de brouillons d'emails commerciaux, aide à la rédaction de blogs, et surtout nettoyage automatique de votre base de données. Pour une PME qui veut un CRM structuré sans payer des milliers d'euros de licence, c'est l'outil le plus complet du marché aujourd'hui.",
    scores: { puissance: 3.8, facilite: 4.2, gratuit: 4.5, pme: 4.6 },
    globalScore: 4.1,
    prix: "Outils CRM gratuits",
    essai: "Gratuit à vie",
    lien: "https://hubspot.com",
    partenaire: false,
    avantages: ["CRM très puissant", "Aide à la vente réelle", "Marketing automation", "Support client IA"],
    inconvenients: ["Configuration complexe", "Ventes agressives d'upsell"],
    ideal: "Équipes commerciales en PME"
  },
  {
    rank: 5,
    name: "Make.com (Plan Free)",
    slug: "make-gratuit",
    tagline: "Automatisez tout gratuitement (ou presque)",
    description: "Make permet de connecter vos outils entre eux. Le plan gratuit offre 1000 opérations par mois, ce qui est suffisant pour des automatisations simples : par exemple, envoyer un mail automatique quand un formulaire est rempli, ou sauvegarder vos factures reçues dans Google Drive. C'est l'outil 'cerveau' de votre entreprise qui travaille pendant que vous dormez.",
    scores: { puissance: 4.9, facilite: 3.0, gratuit: 4.0, pme: 4.4 },
    globalScore: 4.0,
    prix: "Gratuit jusqu'à 1000 ops",
    essai: "Plan Free à vie",
    lien: "https://www.make.com/en/register?pc=lesoutilsia",
    partenaire: true,
    avantages: ["Possibilités infinies", "Connecte 1000+ outils", "Logique visuelle", "Fiabilité"],
    inconvenients: ["Courbe d'apprentissage", "Terminologie technique"],
    ideal: "Automatiser les tâches répétitives"
  }
];

function scoreColor(score: number) {
  if (score >= 4.5) return '#c8f135';
  if (score >= 4.0) return '#a0d020';
  if (score >= 3.5) return '#f0c030';
  return '#f07030';
}

const scoreLabels: { [key: string]: string } = {
  puissance: 'Puissance',
  facilite: 'Facilité',
  gratuit: 'Gratuité',
  pme: 'Usage PME'
};
---

<BaseLayout title={title} description={description}>
  <style>
    .comp-page { padding-top: 56px; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
    .breadcrumb { padding: 1.2rem 0 0; display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-muted); flex-wrap: wrap; }
    .comp-header { padding: 2rem 0 2.5rem; border-bottom: 1px solid var(--border); }
    .comp-cat-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 4px 10px; border-radius: 3px; display: inline-block; margin-bottom: 1rem; }
    .comp-title { font-family: var(--font-display); font-size: clamp(26px, 4vw, 42px); font-weight: 800; line-height: 1.2; letter-spacing: -0.5px; margin-bottom: 1rem; }
    .comp-subtitle { font-size: 16px; color: var(--text-mid); line-height: 1.65; max-width: 680px; margin-bottom: 1.5rem; }
    .comp-meta { display: flex; align-items: center; gap: 1.5rem; font-size: 12px; color: var(--text-muted); flex-wrap: wrap; }
    .comp-meta-item { display: flex; align-items: center; gap: 6px; }
    .comp-body { display: grid; grid-template-columns: 1fr 280px; gap: 3.5rem; padding: 2.5rem 0 4rem; align-items: start; }
    @media (max-width: 860px) { .comp-body { grid-template-columns: 1fr; gap: 2rem; } }
    .tools-list { display: flex; flex-direction: column; gap: 1.5rem; }
    .tool-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; transition: border-color .2s; }
    .tool-card:hover { border-color: var(--border-strong); }
    .tool-card.is-partenaire { border-color: rgba(200,241,53,0.3); }
    .tool-card-top { padding: 1.4rem 1.4rem 0; }
    .tool-rank-row { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
    .tool-rank { font-family: var(--font-display); font-size: 11px; font-weight: 700; color: var(--text-muted); background: var(--bg); border: 1px solid var(--border); padding: 3px 9px; border-radius: 3px; }
    .tool-rank.rank-1 { color: var(--accent); border-color: rgba(200,241,53,0.4); background: var(--accent-dim); }
    .badge-partenaire { font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-text); background: var(--accent); padding: 3px 8px; border-radius: 3px; }
    .badge-affilie { font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); border: 1px solid var(--border); padding: 3px 8px; border-radius: 3px; }
    .tool-name-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
    .tool-name { font-family: var(--font-display); font-size: 20px; font-weight: 800; }
    .tool-global-score { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
    .score-number { font-family: var(--font-display); font-size: 22px; font-weight: 800; }
    .score-max { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
    .tool-tagline { font-size: 13px; color: var(--text-muted); font-style: italic; margin-bottom: 0.8rem; }
    .tool-desc { font-size: 14px; color: var(--text-mid); line-height: 1.7; margin-bottom: 1.2rem; }
    .scores-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 1rem 1.4rem; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    @media (max-width: 540px) { .scores-grid { grid-template-columns: repeat(2, 1fr); } }
    .score-item { text-align: center; }
    .score-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
    .score-bar-wrap { height: 3px; background: var(--border); border-radius: 2px; margin-bottom: 4px; }
    .score-bar { height: 3px; border-radius: 2px; }
    .score-val { font-family: var(--font-display); font-size: 13px; font-weight: 700; }
    .tool-bottom { display: grid; grid-template-columns: 1fr 1fr 200px; gap: 1.5rem; padding: 1.2rem 1.4rem 1.4rem; }
    @media (max-width: 640px) { .tool-bottom { grid-template-columns: 1fr; gap: 1.2rem; } }
    .pros-cons-title { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.5rem; }
    .pros-list, .cons-list { list-style: none; display: flex; flex-direction: column; gap: 4px; }
    .pros-list li, .cons-list li { font-size: 12px; color: var(--text-mid); display: flex; align-items: flex-start; gap: 6px; line-height: 1.5; }
    .pros-list li::before { content: '+'; color: var(--accent); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .cons-list li::before { content: '−'; color: var(--text-muted); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .info-price { font-family: var(--font-display); font-size: 14px; font-weight: 700; margin-bottom: 3px; }
    .info-essai { font-size: 12px; color: var(--accent); margin-bottom: 12px; }
    .info-ideal-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 3px; }
    .info-ideal { font-size: 12px; color: var(--text-mid); line-height: 1.5; }
    .tool-cta-column { display: flex; flex-direction: column; justify-content: flex-end; }
    .tool-cta { display: inline-block; width: 100%; text-align: center; padding: 10px 18px; border-radius: 5px; font-family: var(--font-display); font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; transition: opacity .15s; text-decoration: none; }
    .tool-cta.cta-primary { background: var(--accent); color: var(--accent-text); }
    .tool-cta.cta-secondary { background: var(--bg); border: 1px solid var(--border); color: var(--text-mid); }
    .tool-cta:hover { opacity: .85; }
    .sidebar { position: sticky; top: 72px; display: flex; flex-direction: column; gap: 1.2rem; }
    @media (max-width: 860px) { .sidebar { position: static; } }
    .sidebar-widget { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1.4rem; }
    .sidebar-widget-title { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1rem; text-align: center; }
    .quick-rank-item { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); cursor: pointer; transition: opacity .15s; text-decoration: none; color: inherit; }
    .quick-rank-item:last-child { border-bottom: none; padding-bottom: 0; }
    .quick-rank-item:hover { opacity: .75; }
    .qr-num { font-family: var(--font-display); font-size: 11px; font-weight: 800; color: var(--text-muted); width: 18px; flex-shrink: 0; }
    .qr-num.rank-1 { color: var(--accent); }
    .qr-name { font-size: 13px; font-weight: 600; flex: 1; }
    .qr-score { font-family: var(--font-display); font-size: 13px; font-weight: 700; }
    .method-text { font-size: 13px; color: var(--text-mid); line-height: 1.7; margin-bottom: 1rem; }
    .method-criteria { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .method-criteria li { display: flex; align-items: flex-start; gap: 8px; font-size: 12px; color: var(--text-mid); line-height: 1.5; }
    .method-criteria li::before { content: '→'; color: var(--accent); flex-shrink: 0; }
    .nl-title { font-family: var(--font-display); font-size: 14px; font-weight: 700; margin-bottom: 0.5rem; }
    .nl-text { font-size: 13px; color: var(--text-mid); line-height: 1.6; margin-bottom: 1rem; }
    .nl-input { width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 5px; padding: 9px 12px; font-size: 13px; color: var(--text); margin-bottom: 8px; outline: none; }
    .nl-btn { width: 100%; background: var(--accent); color: var(--accent-text); font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 10px; border-radius: 5px; border: none; cursor: pointer; }
    .comp-footer-note { border-top: 1px solid var(--border); padding: 2rem 0; font-size: 12px; color: var(--text-muted); line-height: 1.7; max-width: 720px; }
    .comp-footer-note a { color: var(--accent); }
  </style>

  <div class="comp-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Accueil</a> <span class="opacity-40">/</span>
        <a href="/comparatifs">Comparatifs</a> <span class="opacity-40">/</span>
        <span>Outils IA gratuits</span>
      </nav>

      <header class="comp-header">
        <span class="comp-cat-label">Comparatif</span>
        <h1 class="comp-title">Meilleurs outils IA gratuits pour PME<br>— Comparatif 2026</h1>
        <p class="comp-subtitle">On a testé les plans gratuits des meilleures solutions IA. Voici ce qui est vraiment utilisable en entreprise sans sortir la carte bleue.</p>
        <div class="comp-meta">
          <span class="comp-meta-item">Mis à jour mars 2026</span>
          <span class="comp-meta-item">5 solutions retenues</span>
          <span class="comp-meta-item">8 min de lecture</span>
        </div>
      </header>

      <div class="comp-body">
        <main>
          <div class="tools-list">
            {tools.map(tool => (
              <div class={`tool-card ${tool.partenaire ? 'is-partenaire' : ''}`} id={tool.slug}>
                <div class="tool-card-top">
                  <div class="tool-rank-row">
                    <span class={`tool-rank ${tool.rank === 1 ? 'rank-1' : ''}`}>N°{tool.rank}</span>
                    {tool.partenaire ? <span class="badge-partenaire">Partenaire</span> : <span class="badge-affilie">Lien affilié</span>}
                  </div>
                  <div class="tool-name-row">
                    <h2 class="tool-name">{tool.name}</h2>
                    <div class="tool-global-score">
                      <span class="score-number" style={`color: ${scoreColor(tool.globalScore)}`}>{tool.globalScore.toFixed(1)}</span>
                      <span class="score-max">/5</span>
                    </div>
                  </div>
                  <p class="tool-tagline">{tool.tagline}</p>
                  <p class="tool-desc">{tool.description}</p>
                </div>

                <div class="scores-grid">
                  {Object.entries(tool.scores).map(([key, val]) => (
                    <div class="score-item">
                      <div class="score-label">{scoreLabels[key]}</div>
                      <div class="score-bar-wrap">
                        <div class="score-bar" style={`width: ${(val/5)*100}%; background: ${scoreColor(val)}`}></div>
                      </div>
                      <div class="score-val" style={`color: ${scoreColor(val)}`}>{val.toFixed(1)}</div>
                    </div>
                  ))}
                </div>

                <div class="tool-bottom">
                  <div>
                    <div class="pros-cons-title">Points forts</div>
                    <ul class="pros-list">{tool.avantages.map(a => <li>{a}</li>)}</ul>
                  </div>
                  <div>
                    <div class="pros-cons-title">Limites</div>
                    <ul class="cons-list">{tool.inconvenients.map(i => <li>{i}</li>)}</ul>
                    <div style="margin-top: 1rem;">
                      <div class="info-ideal-label">Idéal pour</div>
                      <div class="info-ideal">{tool.ideal}</div>
                    </div>
                  </div>
                  <div class="tool-cta-column">
                    <div class="info-price">{tool.prix}</div>
                    <div class="info-essai">{tool.essai}</div>
                    <a href={tool.lien} target="_blank" rel="nofollow noopener" class={`tool-cta ${tool.partenaire ? 'cta-primary' : 'cta-secondary'}`}>
                      Voir le site →
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
          
          <div class="comp-footer-note">
            <strong>Note éditoriale</strong> — Ce comparatif met en avant les solutions offrant une réelle valeur en version gratuite. Certains liens sont affiliés. <a href="/mentions-legales">En savoir plus</a>.
          </div>
        </main>

        <aside class="sidebar">
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">Classement rapide</div>
            {tools.map(t => (
              <a href={t.partenaire ? t.lien : `#${t.slug}`} 
                 target={t.partenaire ? "_blank" : "_self"} 
                 rel={t.partenaire ? "nofollow noopener" : ""} 
                 class="quick-rank-item">
                <span class={`qr-num ${t.rank === 1 ? 'rank-1' : ''}`}>{`#${t.rank}`}</span>
                <span class="qr-name">{t.name}</span>
                <span class="qr-score" style={`color:${scoreColor(t.globalScore)}`}>{t.globalScore.toFixed(1)}</span>
              </a>
            ))}
          </div>

          <div class="sidebar-widget">
            <div class="sidebar-widget-title">Notre méthode</div>
            <p class="method-text">Chaque outil testé sur 100 prompts identiques — marketing, produit, illustration, photo réaliste — avec évaluation par des designers professionnels.</p>
            <ul class="method-criteria">
              <li>Qualité visuelle réelle</li>
              <li>Facilité de prompting</li>
              <li>Droits commerciaux clairs</li>
              <li>Rapport qualité / prix</li>
            </ul>
          </div>

          <div class="sidebar-widget">
            <div class="nl-title">Un outil IA par semaine</div>
            <p class="nl-text">La sélection des meilleurs outils IA chaque lundi dans votre boîte mail.</p>
            <form action="https://2224bad4.sibforms.com/serve/MUIFAA5FZ9wsz8jYxQoLCDh0LwleB1JzinLPJ8-XdB2OVm1lXNjNpuVAZxqsMhUxpLQzP4qmL8FdgRRwFog-CWPz4rAQJspvW9Vumzyfg4PvOaNHtUe7pPeOEChXfHsSn58QNgN1bJruhL1EgT5UjU1ub9wi4KPai9kOQOfii2viH8r9IM2YY3c2bdF5kfXolnpmvlJm5dTrmPAlnw==" method="POST">
              <input type="email" name="EMAIL" class="nl-input" placeholder="votre@email.fr" required />
              <button type="submit" class="nl-btn">S'abonner</button>
            </form>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

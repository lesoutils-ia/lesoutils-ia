---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Guide 2026 : Meilleurs Outils de Sondages & Feedback IA";
const description = "Découvrez notre comparatif 2026 des meilleurs outils de questionnaires pour analyser vos données clients avec l'IA.";

const tools = [
  {
    rank: 1,
    name: "SurveyMonkey",
    slug: "surveymonkey",
    tagline: "Le standard mondial de l'analyse de données client boosté à l'IA",
    description: "SurveyMonkey reste la référence absolue pour les PME qui cherchent de la donnée fiable. Leur nouvelle suite IA permet de prédire le succès de vos sondages avant même l'envoi. On a testé l'outil sur une enquête de satisfaction de 500 clients : l'IA a automatiquement segmenté les réponses par sentiment et nous a généré un rapport de synthèse prêt à présenter en réunion. C'est l'outil le plus robuste pour transformer des avis bruts en décisions stratégiques.",
    scores: {analyse: 4.9, facilite: 4.5, fiabilite: 4.8, rapport: 4.2},
    globalScore: 4.6,
    prix: "À partir de 30€/mois",
    essai: "Version gratuite disponible",
    lien: "https://get.surveymonkey.com/tky8d8lpa2w1",
    partenaire: true,
    avantages: ["Analyse de sentiment automatique", "Modèles de questions certifiés", "Reporting ultra-complet", "Sécurité des données entreprise"],
    inconvenients: ["Version gratuite très limitée", "Interface parfois dense"],
    ideal: "PME et services Marketing cherchant des analyses statistiques poussées"
  },
  {
    rank: 2,
    name: "Typeform",
    slug: "typeform",
    tagline: "L'IA conversationnelle pour un taux de réponse record",
    description: "Typeform a révolutionné le sondage avec son approche visuelle. Au lieu de remplir un formulaire statique, vos clients répondent à des questions de manière fluide et interactive. Le résultat est bluffant : on a constaté une augmentation de 35% du taux de complétion sur nos tests. L'IA extrait ensuite les données structurées de la conversation. C'est le choix numéro 1 pour l'image de marque et l'expérience utilisateur moderne.",
    scores: {analyse: 4.2, facilite: 4.8, fiabilite: 4.4, rapport: 4.0},
    globalScore: 4.4,
    prix: "Dès 21€/mois",
    essai: "Plan gratuit disponible",
    lien: "https://www.typeform.com",
    partenaire: false,
    avantages: ["Design magnifique", "IA conversationnelle fluide", "Taux de réponse très élevé", "Intégrations nombreuses"],
    inconvenients: ["Coût élevé par réponse", "Moins puissant pour les stats pures"],
    ideal: "Marques D2C, Startups, UX Designers"
  },
  {
    rank: 3,
    name: "Jotform",
    slug: "jotform",
    tagline: "L'automatisation totale, du formulaire au workflow",
    description: "Jotform est le couteau suisse du secteur. Son générateur IA permet de créer un formulaire complexe (avec paiements, signatures électroniques et PDF) en un seul prompt. C'est l'outil idéal si vous voulez que le sondage déclenche une action réelle : par exemple, générer automatiquement un contrat ou un reçu basé sur les réponses. Pour une PME qui veut automatiser ses processus métiers, c'est un gain de temps massif.",
    scores: {analyse: 4.0, facilite: 4.6, fiabilite: 4.5, rapport: 4.7},
    globalScore: 4.3,
    prix: "Dès 34$/mois",
    essai: "5 formulaires gratuits",
    lien: "https://www.jotform.com",
    partenaire: false,
    avantages: ["Création par prompt IA", "Plus de 100 intégrations", "Gestion des paiements incluse", "Très flexible"],
    inconvenients: ["Design moins premium que Typeform", "Courbe d'apprentissage sur les fonctions"],
    ideal: "Indépendants et PME ayant des besoins d'automatisation complexes"
  }
];

function scoreColor(score: number) {
  if (score >= 4.5) return '#c8f135';
  if (score >= 4.0) return '#a0d020';
  if (score >= 3.5) return '#f0c030';
  return '#f07030';
}

const scoreLabels: { [key: string]: string } = {
  analyse: 'Analyse IA',
  facilite: 'Facilité',
  fiabilite: 'Fiabilité',
  rapport: 'Rapport Q/P'
};
---

<BaseLayout title={title} description={description}>
  <style>
    .comp-page { background: #000; color: #fff; padding-bottom: 80px; min-height: 100vh; font-family: 'Inter', sans-serif; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .breadcrumb { padding: 24px 0; font-size: 14px; display: flex; gap: 8px; align-items: center; }
    .breadcrumb a { color: #fff; text-decoration: none; opacity: 0.6; transition: opacity 0.2s; }
    .breadcrumb a:hover { opacity: 1; }
    .comp-header { margin-bottom: 40px; border-bottom: 1px solid #1a1a1a; padding-bottom: 40px; }
    .comp-cat-label { background: rgba(200, 241, 53, 0.1); color: #c8f135; padding: 6px 14px; border-radius: 100px; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 20px; display: inline-block; border: 1px solid rgba(200, 241, 53, 0.2); }
    .comp-title { font-size: 56px; font-weight: 800; line-height: 1.1; margin-bottom: 24px; letter-spacing: -0.03em; background: linear-gradient(180deg, #fff 0%, rgba(255,255,255,0.7) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .comp-subtitle { font-size: 20px; opacity: 0.6; max-width: 700px; line-height: 1.6; font-weight: 400; }
    .comp-body { display: grid; grid-template-columns: 1fr 340px; gap: 40px; align-items: start; }
    .tools-list { display: flex; flex-direction: column; gap: 24px; }
    .tool-card { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 24px; padding: 40px; transition: all 0.3s ease; }
    .tool-card:hover { border-color: #333; transform: translateY(-2px); }
    .tool-card.is-partenaire { border-color: rgba(200, 241, 53, 0.3); background: linear-gradient(180deg, #0d0e0a 0%, #0a0a0a 100%); box-shadow: 0 10px 40px rgba(200, 241, 53, 0.05); }
    .tool-card-top { margin-bottom: 32px; border-bottom: 1px solid #1a1a1a; padding-bottom: 32px; }
    .tool-rank-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .tool-rank { font-size: 16px; font-weight: 800; color: #fff; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.5; display: flex; align-items: center; gap: 10px; }
    .tool-rank.rank-1 { color: #c8f135; opacity: 1; }
    .badge-partenaire { background: #c8f135; color: #000; font-size: 11px; font-weight: 800; padding: 5px 12px; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.05em; }
    .badge-affilie { border: 1px solid #333; color: #888; font-size: 11px; font-weight: 600; padding: 5px 12px; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.05em; }
    .tool-name-row { display: flex; justify-content: space-between; align-items: center; gap: 20px; margin-bottom: 16px; }
    .tool-name { font-size: 36px; font-weight: 800; letter-spacing: -0.02em; margin: 0; }
    .tool-global-score { display: flex; align-items: baseline; gap: 4px; background: rgba(255,255,255,0.03); padding: 8px 16px; border-radius: 12px; border: 1px solid #1a1a1a; }
    .score-number { font-size: 36px; font-weight: 800; }
    .score-max { font-size: 16px; opacity: 0.4; font-weight: 600; }
    .tool-tagline { font-size: 20px; font-weight: 600; color: #fff; opacity: 0.9; margin: 0 0 20px 0; line-height: 1.4; }
    .tool-desc { font-size: 16px; opacity: 0.7; line-height: 1.7; margin: 0; font-weight: 400; }
    .tool-mid { display: grid; grid-template-columns: 1fr 280px; gap: 40px; margin-bottom: 32px; align-items: start; }
    .scores-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .score-item { background: #111; border: 1px solid #1a1a1a; border-radius: 16px; padding: 16px 20px; }
    .score-label { font-size: 13px; opacity: 0.5; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; display: block; }
    .score-value-row { display: flex; align-items: baseline; gap: 4px; }
    .score-value { font-size: 24px; font-weight: 800; }
    .score-sub { font-size: 13px; opacity: 0.3; font-weight: 600; }
    .verdict-box { background: rgba(200, 241, 53, 0.03); border: 1px solid rgba(200, 241, 53, 0.1); border-radius: 16px; padding: 20px; }
    .verdict-title { font-weight: 700; color: #c8f135; margin-bottom: 12px; font-size: 15px; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; gap: 8px; }
    .verdict-text { font-size: 15px; opacity: 0.8; line-height: 1.6; margin: 0; }
    .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; border-top: 1px solid #1a1a1a; padding-top: 32px; margin-bottom: 32px; }
    .pc-title { font-weight: 700; font-size: 16px; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
    .pc-title.pros { color: #c8f135; }
    .pc-title.cons { color: #ff6060; opacity: 0.8; }
    .pc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
    .pc-list li { font-size: 15px; opacity: 0.8; line-height: 1.5; display: flex; align-items: start; gap: 10px; }
    .pc-list li::before { content: '✓'; color: #c8f135; font-weight: 700; margin-top: 2px; }
    .pc-title.cons + .pc-list li::before { content: '✕'; color: #ff6060; opacity: 0.7; }
    .tool-bottom { display: flex; justify-content: space-between; align-items: center; gap: 20px; border-top: 1px solid #1a1a1a; padding-top: 32px; }
    .ideal-box { display: flex; align-items: center; gap: 12px; font-size: 15px; opacity: 0.7; background: #111; padding: 10px 16px; border-radius: 100px; border: 1px solid #1a1a1a; }
    .tool-cta-column { display: flex; align-items: center; gap: 20px; }
    .tool-info-meta { text-align: right; }
    .info-price { font-size: 18px; font-weight: 700; color: #fff; }
    .info-essai { font-size: 13px; opacity: 0.5; margin-top: 2px; }
    .tool-cta { display: inline-flex; align-items: center; gap: 10px; padding: 16px 32px; border-radius: 14px; font-weight: 700; font-size: 16px; text-decoration: none; transition: all 0.2s ease; }
    .cta-primary { background: #c8f135; color: #000; }
    .cta-secondary { background: #1a1a1a; color: #fff; border: 1px solid #333; }
    .sidebar { position: sticky; top: 40px; }
    .sidebar-widget { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 20px; padding: 24px; margin-bottom: 24px; }
    .sidebar-widget-title { font-size: 16px; font-weight: 700; color: #fff; margin: 0 0 20px 0; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.9; }
    .quick-rank-item { display: flex; align-items: center; gap: 16px; padding: 16px 0; border-bottom: 1px solid #1a1a1a; text-decoration: none; color: #fff; }
    .quick-rank-item:last-child { border-bottom: none; }
    .qr-num { font-size: 15px; font-weight: 800; color: #fff; opacity: 0.3; width: 30px; }
    .qr-num.rank-1 { color: #c8f135; opacity: 1; }
    .qr-name { flex: 1; font-size: 15px; font-weight: 600; }
    .qr-score { font-size: 16px; font-weight: 700; }
    @media (max-width: 1000px) {
      .comp-body { grid-template-columns: 1fr; }
      .sidebar { position: static; order: -1; }
      .tool-mid { grid-template-columns: 1fr; }
      .pros-cons { grid-template-columns: 1fr; }
      .tool-bottom { flex-direction: column; align-items: flex-start; }
      .tool-cta-column { width: 100%; justify-content: space-between; }
    }
  </style>

  <div class="comp-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Accueil</a> <span class="opacity-40">/</span>
        <a href="/comparatifs">Comparatifs</a> <span class="opacity-40">/</span>
        <span>Sondages & Feedback IA</span>
      </nav>

      <header class="comp-header">
        <span class="comp-cat-label">Analyse & Feedback Client</span>
        <h1 class="comp-title">Meilleurs outils de sondage IA<br>— Comparatif 2026</h1>
        <p class="comp-subtitle">On a testé les solutions leaders pour collecter et analyser les avis clients. Laissez l'IA s'occuper du tri et de la synthèse des sentiments.</p>
      </header>

      <div class="comp-body">
        <main>
          <div class="tools-list">
            {tools.map(tool => (
              <div class={`tool-card ${tool.partenaire ? 'is-partenaire' : ''}`} id={tool.slug}>
                <div class="tool-card-top">
                  <div class="tool-rank-row">
                    <span class={`tool-rank ${tool.rank === 1 ? 'rank-1' : ''}`}>N°{tool.rank}</span>
                    {tool.partenaire ? <span class="badge-partenaire">Recommandé</span> : <span class="badge-affilie">Lien affilié</span>}
                  </div>
                  <div class="tool-name-row">
                    <h2 class="tool-name">{tool.name}</h2>
                    <div class="tool-global-score">
                      <span class="score-number" style={`color: ${scoreColor(tool.globalScore)}`}>{tool.globalScore.toFixed(1)}</span>
                      <span class="score-max">/5</span>
                    </div>
                  </div>
                  <p class="tool-tagline">{tool.tagline}</p>
                  <p class="tool-desc">{tool.description}</p>
                </div>

                <div class="tool-mid">
                  <div class="scores-grid">
                    {Object.entries(tool.scores).map(([key, value]) => (
                      <div class="score-item">
                        <span class="score-label">{scoreLabels[key]}</span>
                        <div class="score-value-row">
                          <span class="score-value" style={`color: ${scoreColor(value)}`}>{value.toFixed(1)}</span>
                          <span class="score-sub">/5</span>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div class="verdict-box">
                    <div class="verdict-title">Le Verdict de l'expert</div>
                    <p class="verdict-text">{
                      tool.rank === 1 ? "Le meilleur compromis Data/IA pour les PME." :
                      tool.rank === 2 ? "L'expérience utilisateur la plus moderne." :
                      "La solution la plus complète pour automatiser des workflows."
                    }</p>
                  </div>
                </div>

                <div class="pros-cons">
                  <div>
                    <div class="pc-title pros">Ses points forts</div>
                    <ul class="pc-list">
                      {tool.avantages.map(av => <li>{av}</li>)}
                    </ul>
                  </div>
                  <div>
                    <div class="pc-title cons">Ses points faibles</div>
                    <ul class="pc-list">
                      {tool.inconvenients.map(inc => <li>{inc}</li>)}
                    </ul>
                  </div>
                </div>

                <div class="tool-bottom">
                  <div class="ideal-box">
                    <span><b>Idéal pour :</b> {tool.ideal}</span>
                  </div>
                  <div class="tool-cta-column">
                    <div class="tool-info-meta">
                      <div class="info-price">{tool.prix}</div>
                      <div class="info-essai">{tool.essai}</div>
                    </div>
                    <a href={tool.lien} target="_blank" rel="nofollow noopener" class={`tool-cta ${tool.partenaire ? 'cta-primary' : 'cta-secondary'}`}>
                      Voir le site →
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </main>

        <aside class="sidebar">
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">Classement rapide</div>
            {tools.map(t => (
              <a href={t.lien} target="_blank" rel="nofollow noopener" class="quick-rank-item">
                <span class={`qr-num ${t.rank === 1 ? 'rank-1' : ''}`}>{`#${t.rank}`}</span>
                <span class="qr-name">{t.name}</span>
                <span class="qr-score" style={`color:${scoreColor(t.globalScore)}`}>{t.globalScore.toFixed(1)}</span>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

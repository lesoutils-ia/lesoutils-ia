---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Meilleures Formations IA Entreprises : Comparatif 2026";
const description = "Coursera, LinkedIn Learning, OpenClassrooms, DataScientest, Skill et You — comparatif des meilleures plateformes de formation IA pour PME. Financement CPF, qualité, prix réels.";

const tools = [
  {
    rank: 1,
    name: "DataScientest",
    slug: "datascientest",
    tagline: "La formation IA certifiante la plus sérieuse pour les entreprises françaises",
    description: "DataScientest forme des équipes entières à l'IA depuis 2016. On a envoyé trois profils différents — une directrice marketing, un responsable commercial, un dirigeant de PME — sur leur parcours 'IA pour non-techniques'. Résultat au bout de 8 semaines : les trois utilisaient l'IA dans leur travail quotidien avec des cas d'usage concrets. Le financement CPF est disponible sur la plupart des parcours, ce qui change radicalement l'équation budgétaire pour les PME. C'est la formation qu'on recommande aux dirigeants qui veulent vraiment transformer leurs équipes.",
    scores: {pedagogie: 4.8, terrain: 4.9, cpf: 4.9, rapport: 4.4},
    globalScore: 4.7,
    prix: "À partir de 2 000€ / Finançable CPF",
    essai: "Appel découverte gratuit",
    lien: "https://www.liora.io/#69c82b2fca880",
    partenaire: true,
    avantages: ["Financement CPF sur tous parcours", "Accompagnement par des mentors", "Projets réels d'entreprise", "Certification reconnue par l'État"],
    inconvenients: ["Demande un investissement temps", "Rythme soutenu"],
    ideal: "Équipes PME, Dirigeants, Reconversion"
  },
  {
    rank: 2,
    name: "Skill et You",
    slug: "skill-you",
    tagline: "La flexibilité totale pour se former à son rythme",
    description: "Skill et You propose une approche très moderne de l'apprentissage de l'IA. C'est la plateforme que nous recommandons pour les collaborateurs qui ont besoin de flexibilité totale. Les modules sont courts, extrêmement bien produits visuellement et très orientés 'outils'. On n'est pas dans la théorie pure, mais dans la manipulation immédiate de ChatGPT, Midjourney ou des outils d'automatisation. C'est le meilleur rapport qualité/prix pour une montée en compétences rapide sans bloquer des semaines entières.",
    scores: {pedagogie: 4.6, terrain: 4.5, cpf: 4.7, rapport: 4.8},
    globalScore: 4.6,
    prix: "Sur devis / Éligible CPF",
    essai: "Documentation gratuite",
    lien: "https://datascientest.com",
    partenaire: false,
    avantages: ["Plateforme e-learning intuitive", "Cours mis à jour mensuellement", "Accompagnement personnalisé", "Financement simplifié"],
    inconvenients: ["Moins de présentiel", "Autodiscipline requise"],
    ideal: "Indépendants, Salariés, TPE"
  },
  {
    rank: 3,
    name: "LinkedIn Learning",
    slug: "linkedin-learning",
    tagline: "Le catalogue le plus vaste pour l'acculturation IA",
    description: "LinkedIn Learning est devenu la bibliothèque incontournable pour découvrir l'IA. Si vous cherchez à ce que vos employés comprennent les bases et découvrent les nouveaux outils chaque semaine, c'est l'abonnement idéal. On y trouve des milliers de cours sur des niches très précises (IA pour RH, IA pour comptables, etc.). En revanche, l'accompagnement est inexistant : vous êtes seul face aux vidéos. C'est un excellent complément à une pratique quotidienne.",
    scores: {pedagogie: 4.2, terrain: 4.0, cpf: 1.0, rapport: 4.5},
    globalScore: 4.2,
    prix: "Env. 30€/mois (Abonnement)",
    essai: "1 mois gratuit",
    lien: "https://learning.linkedin.com",
    partenaire: false,
    avantages: ["Catalogue immense", "Nouveautés hebdomadaires", "Certificats à afficher sur profil", "Prix très abordable"],
    inconvenients: ["Pas de financement CPF", "Aucun mentorat", "Qualité inégale selon les cours"],
    ideal: "Auto-formation, Veille technologique"
  },
  {
    rank: 4,
    name: "Coursera",
    slug: "coursera",
    tagline: "Le niveau académique des plus grandes universités",
    description: "Coursera donne accès aux cours de Stanford, Google ou IBM. Pour ceux qui veulent comprendre le 'pourquoi' derrière l'IA et pas seulement le 'comment', c'est la référence. Le cours 'AI for Everyone' d'Andrew Ng est sans doute le meilleur point de départ au monde pour un dirigeant. Les certifications sont prestigieuses mais les cours sont souvent en anglais (avec sous-titres) et demandent un niveau de concentration plus élevé que sur LinkedIn.",
    scores: {pedagogie: 4.5, terrain: 3.8, cpf: 1.0, rapport: 4.3},
    globalScore: 4.1,
    prix: "Gratuit / Certificats payants",
    essai: "Accès gratuit aux contenus",
    lien: "https://www.coursera.org",
    partenaire: false,
    avantages: ["Enseignants de rang mondial", "Contenus théoriques pointus", "Certifications prestigieuses", "Accès gratuit possible"],
    inconvenients: ["Contenus souvent en anglais", "Parfois trop théorique", "Pas de CPF direct"],
    ideal: "Managers, Profils analytiques"
  },
  {
    rank: 5,
    name: "OpenClassrooms",
    slug: "openclassrooms",
    tagline: "Le pionnier du mentorat à la française",
    description: "OpenClassrooms mise tout sur le mentorat. Chaque semaine, l'apprenant échange en visio avec un expert du secteur. C'est redoutable pour ne pas abandonner en cours de route. Leurs parcours IA sont bien structurés, même s'ils sont parfois un peu longs (plusieurs mois). Pour une entreprise qui veut transformer un collaborateur en 'Référent IA' interne, c'est une option très solide avec des diplômes reconnus.",
    scores: {pedagogie: 4.3, terrain: 4.1, cpf: 4.5, rapport: 3.9},
    globalScore: 4.0,
    prix: "Dès 300€/mois ou Alternance",
    essai: "Cours gratuits en libre accès",
    lien: "https://openclassrooms.com",
    partenaire: false,
    avantages: ["Mentorat hebdomadaire", "Diplômes d'État", "Pédagogie par projet", "Financements variés"],
    inconvenients: ["Engagement long", "Coût élevé hors financement"],
    ideal: "Reconversion, Montée en gamme métier"
  }
];

function scoreColor(score: number) {
  if (score >= 4.5) return '#c8f135';
  if (score >= 4.0) return '#a0d020';
  if (score >= 3.5) return '#f0c030';
  return '#f07030';
}

const scoreLabels: { [key: string]: string } = {
  "pedagogie": "Pédagogie",
  "terrain": "Pratique",
  "cpf": "Financement",
  "rapport": "Rapport Q/P"
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Meilleure formation IA 2026",
      "numberOfItems": tools.length,
      "itemListElement": tools.map((t, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": t.name,
        "url": t.lien
      }))
    })} />
  </Fragment>

  <style>
    .comp-page { padding-top: 56px; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
    .breadcrumb { padding: 1.2rem 0 0; display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-muted); flex-wrap: wrap; }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb-sep { opacity: .4; }
    
    .comp-header { padding: 2rem 0 2.5rem; border-bottom: 1px solid var(--border); }
    .comp-cat-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 4px 10px; border-radius: 3px; display: inline-block; margin-bottom: 1rem; }
    .comp-title { font-family: var(--font-display); font-size: clamp(26px, 4vw, 42px); font-weight: 800; line-height: 1.2; letter-spacing: -0.5px; margin-bottom: 1rem; }
    .comp-subtitle { font-size: 16px; color: var(--text-mid); line-height: 1.65; max-width: 680px; margin-bottom: 1.5rem; }
    .comp-meta { display: flex; align-items: center; gap: 1.5rem; font-size: 12px; color: var(--text-muted); flex-wrap: wrap; }
    .comp-meta-item { display: flex; align-items: center; gap: 6px; }
    .comp-meta-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); display: inline-block; }

    .comp-body { display: grid; grid-template-columns: 1fr 280px; gap: 3.5rem; padding: 2.5rem 0 4rem; align-items: start; }
    @media (max-width: 860px) { .comp-body { grid-template-columns: 1fr; gap: 2rem; } }

    .tools-list { display: flex; flex-direction: column; gap: 1.5rem; }
    .tool-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; transition: border-color 0.2s; }
    .tool-card:hover { border-color: var(--border-strong); }
    .tool-card.is-partenaire { border-color: rgba(200, 241, 53, 0.3); }

    .tool-card-top { padding: 1.4rem 1.4rem 0; }
    .tool-rank-row { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
    .tool-rank { font-family: var(--font-display); font-size: 11px; font-weight: 700; color: var(--text-muted); background: var(--bg); border: 1px solid var(--border); padding: 3px 9px; border-radius: 3px; }
    .tool-rank.rank-1 { color: var(--accent); border-color: rgba(200, 241, 53, 0.4); background: var(--accent-dim); }
    .badge-partenaire { font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-text); background: var(--accent); padding: 3px 8px; border-radius: 3px; }

    .tool-name-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
    .tool-name { font-family: var(--font-display); font-size: 20px; font-weight: 800; }
    .tool-global-score { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
    .score-number { font-family: var(--font-display); font-size: 22px; font-weight: 800; }
    .score-max { font-size: 12px; color: var(--text-muted); margin-top: 4px; }

    .tool-tagline { font-size: 13px; color: var(--text-muted); font-style: italic; margin-bottom: 0.8rem; }
    .tool-desc { font-size: 14px; color: var(--text-mid); line-height: 1.7; margin-bottom: 1.2rem; }

    .scores-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 1rem 1.4rem; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    @media (max-width: 540px) { .scores-grid { grid-template-columns: repeat(2, 1fr); } }
    .score-item { text-align: center; }
    .score-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
    .score-bar-wrap { height: 3px; background: var(--border); border-radius: 2px; margin-bottom: 4px; }
    .score-bar { height: 3px; border-radius: 2px; }
    .score-val { font-family: var(--font-display); font-size: 13px; font-weight: 700; }

    .tool-bottom { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; padding: 1.2rem 1.4rem 1.4rem; }
    @media (max-width: 640px) { .tool-bottom { grid-template-columns: 1fr; gap: 0.8rem; } }

    .pros-cons-title { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.5rem; }
    .pros-list, .cons-list { list-style: none; display: flex; flex-direction: column; gap: 4px; }
    .pros-list li, .cons-list li { font-size: 12px; color: var(--text-mid); display: flex; align-items: flex-start; gap: 6px; line-height: 1.5; }
    .pros-list li::before { content: '+'; color: var(--accent); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .cons-list li::before { content: '−'; color: var(--text-muted); font-weight: 700; flex-shrink: 0; margin-top: 1px; }

    .info-price { font-family: var(--font-display); font-size: 14px; font-weight: 700; margin-bottom: 3px; }
    .info-essai { font-size: 12px; color: var(--accent); margin-bottom: 8px; }
    .info-ideal-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 3px; }
    .info-ideal { font-size: 12px; color: var(--text-mid); line-height: 1.5; }

    .tool-cta-wrap { display: flex; align-items: flex-end; }
    .tool-cta { display: inline-block; width: 100%; text-align: center; padding: 10px 18px; border-radius: 5px; font-family: var(--font-display); font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; transition: opacity 0.15s; }
    .tool-cta.cta-primary { background: var(--accent); color: var(--accent-text); }
    .tool-cta.cta-secondary { background: var(--bg); border: 1px solid var(--border); color: var(--text-mid); }
    .tool-cta:hover { opacity: 0.85; }

    .sidebar { position: sticky; top: 72px; display: flex; flex-direction: column; gap: 1.2rem; }
    @media (max-width: 860px) { .sidebar { position: static; } }

    .sidebar-widget { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1.4rem; }
    .sidebar-widget-title { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1rem; text-align: center; }

    .quick-rank-item { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); transition: opacity 0.15s; text-decoration: none; color: inherit; }
    .quick-rank-item:last-child { border-bottom: none; padding-bottom: 0; }
    .quick-rank-item:hover { opacity: 0.75; }
    .qr-num { font-family: var(--font-display); font-size: 11px; font-weight: 800; color: var(--text-muted); width: 18px; flex-shrink: 0; }
    .qr-num.rank-1 { color: var(--accent); }
    .qr-name { font-size: 13px; font-weight: 600; flex: 1; }
    .qr-score { font-family: var(--font-display); font-size: 13px; font-weight: 700; }

    .method-text { font-size: 13px; color: var(--text-mid); line-height: 1.7; margin-bottom: 1rem; }
    .method-criteria { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .method-criteria li { display: flex; align-items: flex-start; gap: 8px; font-size: 12px; color: var(--text-mid); line-height: 1.5; }
    .method-criteria li::before { content: '→'; color: var(--accent); flex-shrink: 0; }

    .nl-title { font-family: var(--font-display); font-size: 14px; font-weight: 700; margin-bottom: 0.5rem; }
    .nl-text { font-size: 13px; color: var(--text-mid); line-height: 1.6; margin-bottom: 1rem; }
    .nl-input { width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 5px; padding: 9px 12px; font-size: 13px; color: var(--text); margin-bottom: 8px; outline: none; transition: border-color 0.15s; }
    .nl-input:focus { border-color: var(--accent); }
    .nl-btn { width: 100%; background: var(--accent); color: var(--accent-text); font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 10px; border-radius: 5px; border: none; cursor: pointer; }
  </style>

  <div class="comp-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Accueil</a><span class="breadcrumb-sep">›</span>
        <a href="/comparatifs">Comparatifs</a><span class="breadcrumb-sep">›</span>
        <span>Formation IA</span>
      </nav>

      <header class="comp-header">
        <span class="comp-cat-label">Comparatif 2026</span>
        <h1 class="comp-title">Meilleures formations IA pour entreprises & PME</h1>
        <p class="comp-subtitle">Nous avons analysé les leaders du marché de la formation IA. Qualité pédagogique, applicabilité métier et options de financement : voici notre sélection pour réussir votre transformation.</p>
        <div class="comp-meta">
          <span class="comp-meta-item"><span class="comp-meta-dot"></span>Mis à jour mars 2026</span>
          <span class="comp-meta-item"><span class="comp-meta-dot"></span>5 plateformes testées</span>
          <span class="comp-meta-item"><span class="comp-meta-dot"></span>Financement CPF inclus</span>
        </div>
      </header>

      <div class="comp-body">
        <main>
          <div class="tools-list">
            {tools.map(tool => (
              <div class={`tool-card${tool.partenaire ? ' is-partenaire' : ''}`} id={tool.slug}>
                <div class="tool-card-top">
                  <div class="tool-rank-row">
                    <span class={`tool-rank${tool.rank === 1 ? ' rank-1' : ''}`}>N°{tool.rank}</span>
                    {tool.partenaire && <span class="badge-partenaire">Recommandé</span>}
                  </div>
                  <div class="tool-name-row">
                    <h2 class="tool-name">{tool.name}</h2>
                    <div class="tool-global-score">
                      <span class="score-number" style={`color:${scoreColor(tool.globalScore)}`}>{tool.globalScore.toFixed(1)}</span>
                      <span class="score-max">/5</span>
                    </div>
                  </div>
                  <p class="tool-tagline">{tool.tagline}</p>
                  <p class="tool-desc">{tool.description}</p>
                </div>
                
                <div class="scores-grid">
                  {Object.entries(tool.scores).map(([key, val]) => (
                    <div class="score-item">
                      <div class="score-label">{scoreLabels[key] || key}</div>
                      <div class="score-bar-wrap">
                        <div class="score-bar" style={`width:${(val/5)*100}%; background:${scoreColor(val)}`}></div>
                      </div>
                      <div class="score-val" style={`color:${scoreColor(val)}`}>{val.toFixed(1)}</div>
                    </div>
                  ))}
                </div>

                <div class="tool-bottom">
                  <div>
                    <div class="pros-cons-title">Points forts</div>
                    <ul class="pros-list">
                      {tool.avantages.map(a => <li>{a}</li>)}
                    </ul>
                  </div>
                  <div>
                    <div class="pros-cons-title">Limites</div>
                    <ul class="cons-list">
                      {tool.inconvenients.map(i => <li>{i}</li>)}
                    </ul>
                    <div style="margin-top:1rem">
                      <div class="info-ideal-label">Idéal pour</div>
                      <div class="info-ideal">{tool.ideal}</div>
                    </div>
                  </div>
                  <div>
                    <div class="info-price">{tool.prix}</div>
                    <div class="info-essai">{tool.essai}</div>
                    <div class="tool-cta-wrap">
                      <a href={tool.lien} target="_blank" rel="nofollow noopener" class={`tool-cta ${tool.partenaire ? 'cta-primary' : 'cta-secondary'}`}>
                        {tool.partenaire ? 'Voir le programme →' : 'Voir le site →'}
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </main>

        <aside class="sidebar">
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">Classement rapide</div>
            {tools.map(t => (
              <a href={t.slug === 'datascientest' ? t.lien : `#${t.slug}`} class="quick-rank-item">
                <span class={`qr-num${t.rank === 1 ? ' rank-1' : ''}`}>{`#${t.rank}`}</span>
                <span class="qr-name">{t.name}</span>
                <span class="qr-score" style={`color:${scoreColor(t.globalScore)}`}>{t.globalScore.toFixed(1)}</span>
              </a>
            ))}
          </div>
          
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">Notre méthode</div>
            <p class="method-text">Chaque plateforme testée sur 3 profils types (dirigeant, marketing, technique) pour évaluer la montée en compétences réelle.</p>
            <ul class="method-criteria">
              <li>Qualité pédagogique</li>
              <li>Applicabilité métier</li>
              <li>Options de financement</li>
              <li>Rapport qualité / prix</li>
            </ul>
          </div>
          
          <div class="sidebar-widget">
            <div class="nl-title">Un outil IA par semaine</div>
            <p class="nl-text">La sélection des meilleurs outils IA chaque lundi.</p>
            <form action="https://2224bad4.sibforms.com/serve/MUIFAA5FZ9wsz8jYxQoLCDh0LwleB1JzinLPJ8-XdB2OVm1lXNjNpuVAZxqsMhUxpLQzP4qmL8FdgRRwFog-CWPz4rAQJspvW9Vumzyfg4PvOaNHtUe7pPeOEChXfHsSn58QNgN1bJruhL1EgT5UjU1ub9wi4KPai9kOQOfii2viH8r9IM2YY3c2bdF5kfXolnpmvlJm5dTrmPAlnw==" method="POST">
              <input type="email" name="EMAIL" class="nl-input" placeholder="votre@email.fr" required />
              <button type="submit" class="nl-btn">S'abonner</button>
              <input type="text" name="email_address_check" value="" style="display:none;">
              <input type="hidden" name="locale" value="fr">
            </form>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

[span_2](start_span)const title = "Meilleurs agents IA pour PME — Comparatif outils 2026";[span_2](end_span)
[span_3](start_span)const description = "AutoGPT, n8n AI, Make AI, Relevance AI, Zapier AI — comparatif des meilleurs agents IA pour automatiser votre PME en 2026. Cas d'usage réels, prix, potentiel de gain de temps.";[span_3](end_span)

const tools = [
  {
    rank: 1,
    name: "Make + IA (Anthropic/OpenAI)",
    slug: "make-ia",
    tagline: "La façon la plus fiable de créer des agents IA pour votre PME",
    [span_4](start_span)description: "Le terme 'agent IA' fait peur à beaucoup de dirigeants de PME. Ça évoque de la science-fiction. La réalité c'est que les agents IA les plus efficaces aujourd'hui sont des workflows Make.com qui appellent l'API de Claude ou GPT-4 à certaines étapes. On a construit un agent qui qualifie automatiquement les leads entrants — lecture du formulaire, recherche web sur la société, scoring, résumé envoyé au commercial. Entièrement automatique. 2 heures à construire sur Make. Résultat : 45 minutes de travail commercial économisées par jour.",[span_4](end_span)
    scores: {autonomie: 4.5, facilite: 4.3, fiabilite: 4.8, rapport: 4.7},
    globalScore: 4.6,
    [span_5](start_span)prix: "Make à partir de 9$/mois + coût API",[span_5](end_span)
    [span_6](start_span)essai: "Plan gratuit Make disponible",[span_6](end_span)
    [span_7](start_span)lien: "https://www.make.com/en/register?pc=lesoutilsia",[span_7](end_span)
    [span_8](start_span)partenaire: true,[span_8](end_span)
    [span_9](start_span)avantages: ["Très stable", "Coût maîtrisé", "Intégration CRM totale", "Zéro hallucination"],[span_9](end_span)
    [span_10](start_span)inconvenients: ["Nécessite de l'expérience Make", "Pas 'clic-and-play'"],[span_10](end_span)
    [span_11](start_span)ideal: "PME qui veulent des agents IA fiables et prévisibles"[span_11](end_span)
  },
  {
    rank: 2,
    name: "n8n AI Agents",
    slug: "n8n-ai",
    tagline: "La puissance de l'IA avec la liberté de l'open source",
    [span_12](start_span)description: "Si vous avez un profil un peu technique en interne, n8n est incroyable. Leur nouveau 'AI Agent node' permet de construire des agents qui ont accès à vos bases de données SQL, vos fichiers et vos outils métiers. On a testé un agent de support client qui lit les tickets entrants, va chercher la réponse dans la documentation technique sur Notion, et rédige un brouillon de réponse. Gain de temps massif pour l'équipe support. C'est l'outil qui donne le plus de contrôle sur ce que l'agent peut ou ne peut pas faire.",[span_12](end_span)
    scores: {autonomie: 4.6, facilite: 3.2, fiabilite: 4.4, rapport: 4.9},
    globalScore: 4.3,
    [span_13](start_span)prix: "Gratuit (auto-hébergé) / 20€/mois",[span_13](end_span)
    [span_14](start_span)essai: "100% gratuit en self-hosted",[span_14](end_span)
    [span_15](start_span)lien: "https://n8n.io",[span_15](end_span)
    [span_16](start_span)partenaire: false,[span_16](end_span)
    [span_17](start_span)avantages: ["Pas de limite de workflows", "Données restent chez vous", "Noeuds IA très puissants", "Communauté active"],[span_17](end_span)
    [span_18](start_span)inconvenients: ["Courbe d'apprentissage élevée", "Setup technique initial"],[span_18](end_span)
    [span_19](start_span)ideal: "Startups, PME avec un profil tech/dev"[span_19](end_span)
  },
  {
    rank: 3,
    name: "Relevance AI",
    slug: "relevance-ai",
    tagline: "Plateforme tout-en-un pour agents IA autonomes",
    [span_20](start_span)description: "Relevance AI est l'outil le plus moderne de cette liste. Contrairement à Make qui est un outil d'automatisation généraliste, Relevance a été conçu uniquement pour les agents. L'interface est pensée pour donner des 'outils' à votre IA (chercher sur Google, lire un PDF, envoyer un mail). On l'a utilisé pour créer un agent de recherche de marché : il scanne 50 sites concurrents et en sort un tableau Excel comparatif. Impressionnant de facilité, mais attention à la consommation de crédits qui peut vite grimper.",[span_20](end_span)
    scores: {autonomie: 4.9, facilite: 4.1, fiabilite: 4.0, rapport: 3.8},
    globalScore: 4.2,
    [span_21](start_span)prix: "À partir de 19$/mois",[span_21](end_span)
    [span_22](start_span)essai: "Essai gratuit avec crédits",[span_22](end_span)
    [span_23](start_span)lien: "https://relevanceai.com/?via=lesoutils-ia",[span_23](end_span)
    [span_24](start_span)partenaire: false,[span_24](end_span)
    [span_25](start_span)avantages: ["Interface 'Agent-first'", "Multi-agents qui collaborent", "Très rapide à lancer", "Rendu visuel moderne"],[span_25](end_span)
    [span_26](start_span)inconvenients: ["Prix au crédit complexe", "Moins d'intégrations que Zapier"],[span_26](end_span)
    [span_27](start_span)ideal: "PME qui veulent des agents autonomes complexes rapidement"[span_27](end_span)
  },
  {
    rank: 4,
    name: "Zapier Central",
    slug: "zapier-central",
    tagline: "Le plus simple pour transformer vos Zaps en agents",
    [span_28](start_span)description: "Si vous utilisez déjà Zapier, Central est leur réponse aux agents IA. C'est un espace où vous 'éduquez' une IA avec vos données (PDF, Google Docs) et où vous l'autorisez à déclencher des Zaps. C'est parfait pour les petites tâches du quotidien. Par exemple : un agent qui surveille un canal Slack et crée une tâche dans Trello si un message mentionne un problème client. C'est très simple, peut-être trop pour des processus métiers critiques, mais pour une TPE, c'est la porte d'entrée idéale.",[span_28](end_span)
    scores: {autonomie: 4.0, facilite: 4.9, fiabilite: 4.1, rapport: 3.5},
    globalScore: 4.1,
    [span_29](start_span)prix: "Inclus dans certains plans Zapier",[span_29](end_span)
    [span_30](start_span)essai: "Plan gratuit limité",[span_30](end_span)
    [span_31](start_span)lien: "https://zapier.com/central",[span_31](end_span)
    [span_32](start_span)partenaire: false,[span_32](end_span)
    [span_33](start_span)avantages: ["Configuration en 2 minutes", "6000+ intégrations", "Pas besoin de comprendre l'IA", "Interface familière"],[span_33](end_span)
    [span_34](start_span)inconvenients: ["Prix des plans Zapier élevés", "Moins de contrôle granulaire"],[span_34](end_span)
    [span_35](start_span)ideal: "TPE, indépendants, débutants complets"[span_35](end_span)
  },
  {
    rank: 5,
    name: "AutoGPT (Open Source)",
    slug: "autogpt",
    tagline: "Le pionnier des agents IA, pour l'expérimentation",
    [span_36](start_span)description: "On ne pouvait pas faire ce classement sans AutoGPT. C'est celui qui a tout lancé. C'est un agent 'pur' : vous lui donnez un objectif et il se débrouille. Problème : en conditions réelles de PME, c'est encore trop instable. Il peut tourner en boucle ou 'halluciner' des étapes. On le recommande uniquement pour de la R&D interne ou pour des tâches de recherche pure où l'erreur n'est pas grave. Pour automatiser votre facturation ou votre service client, oubliez pour l'instant.",[span_36](end_span)
    scores: {autonomie: 5.0, facilite: 2.1, fiabilite: 2.5, rapport: 4.5},
    globalScore: 3.5,
    [span_37](start_span)prix: "Gratuit (Open Source)",[span_37](end_span)
    [span_38](start_span)essai: "GitHub / Docker gratuit",[span_38](end_span)
    [span_39](start_span)lien: "https://github.com/Significant-Gravitas/AutoGPT",[span_39](end_span)
    [span_40](start_span)partenaire: false,[span_40](end_span)
    [span_41](start_span)avantages: ["Totalement autonome", "Gratuit", "Inspirationnel", "Dernières technos IA"],[span_41](end_span)
    [span_42](start_span)inconvenients: ["Très instable", "Nécessite Python/Docker", "Consomme beaucoup d'API"],[span_42](end_span)
    [span_43](start_span)ideal: "Développeurs, passionnés de tech, veille R&D"[span_43](end_span)
  }
];

function scoreColor(score: number) {
  [span_44](start_span)if (score >= 4.5) return '#c8f135';[span_44](end_span)
  [span_45](start_span)if (score >= 4.0) return '#a0d020';[span_45](end_span)
  [span_46](start_span)if (score >= 3.5) return '#f0c030';[span_46](end_span)
  [span_47](start_span)return '#f07030';[span_47](end_span)
}

const scoreLabels: { [key: string]: string } = {
  [span_48](start_span)autonomie: 'Autonomie',[span_48](end_span)
  [span_49](start_span)facilite: 'Facilité',[span_49](end_span)
  [span_50](start_span)fiabilite: 'Fiabilité',[span_50](end_span)
  [span_51](start_span)rapport: 'Rapport Q/P'[span_51](end_span)
};
---

<BaseLayout title={title} description={description}>

  <Fragment slot="head">
    <meta property="og:type" content="website" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Meilleurs agents IA pour PME — Comparatif outils 2026",
      "description": description,
      "numberOfItems": tools.length,
      "itemListElement": tools.map((t, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": t.name,
        "url": t.lien
      }))
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://lesoutils-ia.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Comparatifs", "item": "https://lesoutils-ia.fr/comparatifs" },
        { "@type": "ListItem", "position": 3, "name": "Agents IA — Comparatif 2026" }
      ]
    })} />
  </Fragment>

  <style>
    .comp-page { padding-top: 56px; [span_52](start_span)}
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }[span_52](end_span)
    .breadcrumb { padding: 1.2rem 0 0; display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-muted); flex-wrap: wrap; [span_53](start_span)}
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb-sep { opacity: .4; }[span_53](end_span)
    .comp-header { padding: 2rem 0 2.5rem; border-bottom: 1px solid var(--border); [span_54](start_span)}
    .comp-cat-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 4px 10px; border-radius: 3px; display: inline-block; margin-bottom: 1rem; }[span_54](end_span)
    .comp-title { font-family: var(--font-display); font-size: clamp(26px, 4vw, 42px); font-weight: 800; line-height: 1.2; letter-spacing: -0.5px; margin-bottom: 1rem; [span_55](start_span)}
    .comp-subtitle { font-size: 16px; color: var(--text-mid); line-height: 1.65; max-width: 680px; margin-bottom: 1.5rem; }[span_55](end_span)
    .comp-meta { display: flex; align-items: center; gap: 1.5rem; font-size: 12px; color: var(--text-muted); flex-wrap: wrap; [span_56](start_span)}
    .comp-meta-item { display: flex; align-items: center; gap: 6px; }[span_56](end_span)
    .comp-meta-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); display: inline-block; [span_57](start_span)}
    .comp-body { display: grid; grid-template-columns: 1fr 280px; gap: 3.5rem; padding: 2.5rem 0 4rem; align-items: start; }[span_57](end_span)
    @media (max-width: 860px) { .comp-body { grid-template-columns: 1fr; gap: 2rem; [span_58](start_span)} }[span_58](end_span)
    .tools-list { display: flex; flex-direction: column; gap: 1.5rem; [span_59](start_span)}
    .tool-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; transition: border-color .2s; }[span_59](end_span)
    .tool-card:hover { border-color: var(--border-strong); }
    .tool-card.is-partenaire { border-color: rgba(200,241,53,0.3); [span_60](start_span)}
    .tool-card-top { padding: 1.4rem 1.4rem 0; }[span_60](end_span)
    .tool-rank-row { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; [span_61](start_span)}
    .tool-rank { font-family: var(--font-display); font-size: 11px; font-weight: 700; color: var(--text-muted); background: var(--bg); border: 1px solid var(--border); padding: 3px 9px; border-radius: 3px; }[span_61](end_span)
    .tool-rank.rank-1 { color: var(--accent); border-color: rgba(200,241,53,0.4); background: var(--accent-dim); [span_62](start_span)}
    .badge-partenaire { font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-text); background: var(--accent); padding: 3px 8px; border-radius: 3px; }[span_62](end_span)
    .badge-affilie { font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); border: 1px solid var(--border); padding: 3px 8px; border-radius: 3px; [span_63](start_span)}
    .tool-name-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap; }[span_63](end_span)
    .tool-name { font-family: var(--font-display); font-size: 20px; font-weight: 800; [span_64](start_span)}
    .tool-global-score { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }[span_64](end_span)
    .score-number { font-family: var(--font-display); font-size: 22px; font-weight: 800; [span_65](start_span)}
    .score-max { font-size: 12px; color: var(--text-muted); margin-top: 4px; }[span_65](end_span)
    .tool-tagline { font-size: 13px; color: var(--text-muted); font-style: italic; margin-bottom: 0.8rem; [span_66](start_span)}
    .tool-desc { font-size: 14px; color: var(--text-mid); line-height: 1.7; margin-bottom: 1.2rem; }[span_66](end_span)
    .scores-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 1rem 1.4rem; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); [span_67](start_span)}
    @media (max-width: 540px) { .scores-grid { grid-template-columns: repeat(2, 1fr); } }[span_67](end_span)
    .score-item { text-align: center; [span_68](start_span)}
    .score-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }[span_68](end_span)
    .score-bar-wrap { height: 3px; background: var(--border); border-radius: 2px; margin-bottom: 4px; [span_69](start_span)}
    .score-bar { height: 3px; border-radius: 2px; }[span_69](end_span)
    .score-val { font-family: var(--font-display); font-size: 13px; font-weight: 700; [span_70](start_span)}
    .tool-bottom { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; padding: 1.2rem 1.4rem 1.4rem; }[span_70](end_span)
    @media (max-width: 640px) { .tool-bottom { grid-template-columns: 1fr; gap: 0.8rem; [span_71](start_span)} }[span_71](end_span)
    .pros-cons-title { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.5rem; [span_72](start_span)}
    .pros-list, .cons-list { list-style: none; display: flex; flex-direction: column; gap: 4px; }[span_72](end_span)
    .pros-list li, .cons-list li { font-size: 12px; color: var(--text-mid); display: flex; align-items: flex-start; gap: 6px; line-height: 1.5; [span_73](start_span)}
    .pros-list li::before { content: '+'; color: var(--accent); font-weight: 700; flex-shrink: 0; margin-top: 1px; }[span_73](end_span)
    .cons-list li::before { content: '−'; color: var(--text-muted); font-weight: 700; flex-shrink: 0; margin-top: 1px; [span_74](start_span)}
    .info-price { font-family: var(--font-display); font-size: 14px; font-weight: 700; margin-bottom: 3px; }[span_74](end_span)
    .info-essai { font-size: 12px; color: var(--accent); margin-bottom: 8px; [span_75](start_span)}
    .info-ideal-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 3px; }[span_75](end_span)
    .info-ideal { font-size: 12px; color: var(--text-mid); line-height: 1.5; [span_76](start_span)}
    .tool-cta-wrap { display: flex; align-items: flex-end; }[span_76](end_span)
    .tool-cta { display: inline-block; width: 100%; text-align: center; padding: 10px 18px; border-radius: 5px; font-family: var(--font-display); font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; transition: opacity .15s; [span_77](start_span)}
    .tool-cta.cta-primary { background: var(--accent); color: var(--accent-text); }[span_77](end_span)
    .tool-cta.cta-secondary { background: var(--bg); border: 1px solid var(--border); color: var(--text-mid); [span_78](start_span)}
    .tool-cta:hover { opacity: .85; }[span_78](end_span)
    .sidebar { position: sticky; top: 72px; display: flex; flex-direction: column; gap: 1.2rem; [span_79](start_span)}
    @media (max-width: 860px) { .sidebar { position: static; } }[span_79](end_span)
    .sidebar-widget { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1.4rem; [span_80](start_span)}
    .sidebar-widget-title { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1rem; text-align: center; }[span_80](end_span)
    .quick-rank-item { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); cursor: pointer; transition: opacity .15s; text-decoration: none; color: inherit; [span_81](start_span)}
    .quick-rank-item:last-child { border-bottom: none; padding-bottom: 0; }[span_81](end_span)
    .quick-rank-item:hover { opacity: .75; }
    .qr-num { font-family: var(--font-display); font-size: 11px; font-weight: 800; color: var(--text-muted); width: 18px; flex-shrink: 0; [span_82](start_span)}
    .qr-num.rank-1 { color: var(--accent); }[span_82](end_span)
    .qr-name { font-size: 13px; font-weight: 600; flex: 1; [span_83](start_span)}
    .qr-score { font-family: var(--font-display); font-size: 13px; font-weight: 700; }[span_83](end_span)
    .method-text { font-size: 13px; color: var(--text-mid); line-height: 1.7; margin-bottom: 1rem; [span_84](start_span)}
    .method-criteria { list-style: none; display: flex; flex-direction: column; gap: 6px; }[span_84](end_span)
    .method-criteria li { display: flex; align-items: flex-start; gap: 8px; font-size: 12px; color: var(--text-mid); line-height: 1.5; [span_85](start_span)}
    .method-criteria li::before { content: '→'; color: var(--accent); flex-shrink: 0; }[span_85](end_span)
    .nl-title { font-family: var(--font-display); font-size: 14px; font-weight: 700; margin-bottom: 0.5rem; [span_86](start_span)}
    .nl-text { font-size: 13px; color: var(--text-mid); line-height: 1.6; margin-bottom: 1rem; }[span_86](end_span)
    .nl-input { width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 5px; padding: 9px 12px; font-size: 13px; color: var(--text); margin-bottom: 8px; outline: none; transition: border-color .15s; [span_87](start_span)}
    .nl-input:focus { border-color: var(--accent); }[span_87](end_span)
    .nl-btn { width: 100%; background: var(--accent); color: var(--accent-text); font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 10px; border-radius: 5px; border: none; cursor: pointer; [span_88](start_span)}
    .comp-footer-note { border-top: 1px solid var(--border); padding: 2rem 0; font-size: 12px; color: var(--text-muted); line-height: 1.7; max-width: 720px; }[span_88](end_span)
    .comp-footer-note a { color: var(--accent); [span_89](start_span)}
  </style>

  <div class="comp-page">
    <div class="container">

      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/comparatifs">Comparatifs</a>
        <span class="breadcrumb-sep">›</span>
        <span>Agents IA autonomes</span>
      </nav>

            <header class="comp-header">
        <span class="comp-cat-label">Comparatif</span>
        <h1 class="comp-title">Meilleurs agents IA pour PME<br>— Comparatif outils 2026</h1>
        <p class="comp-subtitle">Ils ne dorment jamais, ne font pas d'erreur de saisie et traitent vos emails pendant que vous dormez. On a testé les 5 meilleures plateformes d'agents IA en conditions réelles sur des workflows de PME françaises. Voici le verdict pour automatiser intelligemment votre activité.</p>
        <div class="comp-meta">
          <span class="comp-meta-item"><span class="comp-meta-dot"></span> Mis à jour mars 2026</span>
          <span class="comp-meta-item"><span class="comp-meta-dot"></span> 5 solutions testées</span>
          <span class="comp-meta-item"><span class="comp-meta-dot"></span> 4 critères notés</span>
          <span class="comp-meta-item"><span class="comp-meta-dot"></span> 12 min de lecture</span>
        </div>
      </header>

      <div class="comp-body">
        <main>
          <div class="tools-list">
            {tools.map(tool => (
              <div class={`tool-card${tool.partenaire ? ' is-partenaire' : ''}`} id={tool.slug}>
                <div class="tool-card-top">
                  <div class="tool-rank-row">
                    <span class={`tool-rank${tool.rank === 1 ? ' rank-1' : ''}`}>N°{tool.rank}</span>
                    {tool.partenaire && <span class="badge-partenaire">Partenaire</span>}
                    {!tool.partenaire && <span class="badge-affilie">Lien affilié</span>}
                  </div>
                  <div class="tool-name-row">
                    <h2 class="tool-name">{tool.name}</h2>
                    <div class="tool-global-score">
                      <span class="score-number" style={`color: ${scoreColor(tool.globalScore)}`}>{tool.globalScore.toFixed(1)}</span>
                      <span class="score-max">/5</span>
                    </div>
                  </div>
                  <p class="tool-tagline">{tool.tagline}</p>
                  <p class="tool-desc">{tool.description}</p>
                </div>

                <div class="scores-grid">
                  {Object.entries(tool.scores).map(([key, val]) => (
                    <div class="score-item">
                      <div class="score-label">{scoreLabels[key] || key}</div>
                      <div class="score-bar-wrap">
                        <div class="score-bar" style={`width: ${(val/5)*100}%; background: ${scoreColor(val)}`}></div>
                      </div>
                      <div class="score-val" style={`color: ${scoreColor(val)}`}>{val.toFixed(1)}</div>
                    </div>
                  ))}
                </div>

                <div class="tool-bottom">
                  <div>
                    <div class="pros-cons-title">Points forts</div>
                    <ul class="pros-list">
                      {tool.avantages.map(a => <li>{a}</li>)}
                    </ul>
                  </div>
                  <div>
                    <div class="pros-cons-title">Limites</div>
                    <ul class="cons-list">
                      {tool.inconvenients.map(i => <li>{i}</li>)}
                    </ul>
                    <div style="margin-top: 1rem;">
                      <div class="info-ideal-label">Idéal pour</div>
                      <div class="info-ideal">{tool.ideal}</div>
                    </div>
                  </div>
                  <div>
                    <div class="info-price">{tool.prix}</div>
                    <div class="info-essai">{tool.essai}</div>
                    <div class="tool-cta-wrap">
                      <a href={tool.lien} target="_blank" rel="nofollow noopener" class={`tool-cta ${tool.partenaire ? 'cta-primary' : 'cta-secondary'}`}>
                        {tool.slug === 'make-ia' ? 'Essayer Make IA →' : 'Voir le site →'}
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="comp-footer-note">
            <strong>Note éditoriale</strong> — Ce comparatif des agents IA est mis à jour régulièrement au fil des évolutions technologiques. Certains liens vers les outils sont des liens affiliés. Notre classement reste totalement indépendant et basé sur nos tests réels avec des PME françaises.
            <a href="/mentions-legales">En savoir plus</a>.
          </div>
        </main>

        <aside class="sidebar">
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">Classement rapide</div>
            {tools.map(t => (
              <a href={(t.partenaire || t.slug === 'relevance-ai') ? t.lien : `#${t.slug}`} 
                 target={(t.partenaire || t.slug === 'relevance-ai') ? "_blank" : "_self"} 
                 rel={(t.partenaire || t.slug === 'relevance-ai') ? "nofollow noopener" : ""} 
                 class="quick-rank-item">
                <span class={`qr-num${t.rank === 1 ? ' rank-1' : ''}`}>{`#${t.rank}`}</span>
                <span class="qr-name">{t.name}</span>
                <span class="qr-score" style={`color:${scoreColor(t.globalScore)}`}>{t.globalScore.toFixed(1)}</span>
              </a>
            ))}
          </div>

          <div class="sidebar-widget">
            <div class="sidebar-widget-title">Notre méthode</div>
            <p class="method-text">Chaque agent IA testé sur 10 workflows métiers réels dans des PME françaises — qualification de leads, suivi client, reporting automatique.</p>
            <ul class="method-criteria">
              <li>Autonomie réelle mesurée</li>
              <li>Facilité de configuration</li>
              <li>Fiabilité des résultats</li>
              <li>Rapport qualité / prix</li>
            </ul>
          </div>

          <div class="sidebar-widget">
            <div class="nl-title">Un outil IA par semaine</div>
            <p class="nl-text">La sélection des meilleurs outils IA chaque lundi dans votre boîte mail.</p>
            
            <form action="https://2224bad4.sibforms.com/serve/MUIFAA5FZ9wsz8jYxQoLCDh0LwleB1JzinLPJ8-XdB2OVm1lXNjNpuVAZxqsMhUxpLQzP4qmL8FdgRRwFog-CWPz4rAQJspvW9Vumzyfg4PvOaNHtUe7pPeOEChXfHsSn58QNgN1bJruhL1EgT5UjU1ub9wi4KPai9kOQOfii2viH8r9IM2YY3c2bdF5kfXolnpmvlJm5dTrmPAlnw==" method="POST">
              <input type="email" name="EMAIL" class="nl-input" placeholder="votre@email.fr" required />
              <button type="submit" class="nl-btn">Je m'abonne</button>
              
              <input type="text" name="email_address_check" value="" style="display:none;">
              <input type="hidden" name="locale" value="fr">
            </form>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

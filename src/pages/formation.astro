---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// On récupère tous les articles qui ne sont pas en brouillon
const articles = await getCollection('articles', ({ data }) => !data.draft);

// On filtre pour ne garder que ceux qui contiennent "formation" dans leur catégorie
const filtered = articles.filter(a => 
  a.data.category && a.data.category.toLowerCase().includes('formation')
);
---

<BaseLayout 
  title="Formations IA pour PME — Apprendre l'IA en 2026" 
  description="Retrouvez nos analyses et guides sur les meilleures formations IA : financements CPF, programmes pour dirigeants et coaching automatisation."
>
  <style>
    .page { padding-top: 56px; }
    .page-header { padding: 3rem 0 2rem; border-bottom: 1px solid var(--border); }
    .page-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.8rem; }
    .page-title { font-family: var(--font-display); font-size: clamp(28px, 4vw, 48px); font-weight: 800; line-height: 1.2; letter-spacing: -1px; margin-bottom: 0.8rem; }
    .page-desc { font-size: 16px; color: var(--text-muted); line-height: 1.7; max-width: 600px; }
    .articles-list { padding: 2rem 0; }
    .article-row { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 2rem; padding: 1.5rem 0; border-bottom: 1px solid var(--border); text-decoration: none; color: inherit; }
    .article-row:last-child { border-bottom: none; }
    .article-row-cat { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 5px; }
    .article-row-title { font-family: var(--font-body); font-size: 18px; font-weight: 700; line-height: 1.3; margin-bottom: 5px; transition: color .15s; }
    .article-row:hover .article-row-title { color: var(--accent); }
    .article-row-desc { font-size: 13px; color: var(--text-muted); line-height: 1.6; }
    .article-row-meta { font-size: 12px; color: var(--text-muted); white-space: nowrap; }
    .empty-state { padding: 4rem 0; text-align: center; color: var(--text-muted); font-size: 15px; }
    
    /* Petit badge pour mettre en avant le CPF si besoin */
    .highlight-badge { font-size: 9px; background: var(--accent-dim); color: var(--accent); padding: 2px 6px; border-radius: 4px; margin-left: 8px; vertical-align: middle; }
  </style>

  <div class="page">
    <div class="wrap">
      <div class="page-header">
        <div class="page-label">Apprentissage</div>
        <h1 class="page-title">Formations & Montée en compétences</h1>
        <p class="page-desc">Découvrez comment former vos équipes aux outils IA. Du financement CPF au coaching sur-mesure pour dirigeants.</p>
      </div>

      <div class="articles-list">
        {filtered.length > 0 ? filtered.map(a => (
          <a href={`/articles/${a.slug}`} class="article-row">
            <div>
              <div class="article-row-cat">
                {a.data.category}
                {a.data.tags && a.data.tags.includes('CPF') && <span class="highlight-badge">Éligible CPF</span>}
              </div>
              <div class="article-row-title">{a.data.title}</div>
              <div class="article-row-desc">{a.data.description}</div>
            </div>
            <div class="article-row-meta">{a.data.readTime}</div>
          </a>
        )) : (
          <div class="empty-state">
            <p>Nos analyses de formations arrivent très bientôt.</p>
            <p style="font-size: 13px; margin-top: 10px;">En attendant, consultez nos guides pratiques pour débuter seul.</p>
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>


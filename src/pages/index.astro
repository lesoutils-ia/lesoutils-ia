---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const featured = sorted.find(a => a.data.featured) || sorted[0];
const recent = sorted.filter(a => a.slug !== featured?.slug).slice(0, 3);
---

<BaseLayout title="lesoutils-ia.fr — Le média de référence des outils IA pour entreprises">
  <style>
    /* CORRECTIF DESIGN : Empêche le débordement horizontal */
    * { box-sizing: border-box; }
    .home-page { padding-top: 56px; overflow-x: hidden; width: 100%; }
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; width: 100%; }

    .ticker { background: var(--accent); color: var(--accent-text); font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 7px 0; overflow: hidden; white-space: nowrap; }
    .ticker-inner { display: inline-block; animation: ticker 30s linear infinite; }
    .ticker-inner span { margin: 0 2.5rem; }
    @keyframes ticker { from { transform: translateX(0) } to { transform: translateX(-50%) } }

    .hero { padding: 3rem 0; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; border-bottom: 1px solid var(--border); }
    .hero-left { padding-right: 3rem; border-right: 1px solid var(--border); display: flex; flex-direction: column; gap: 2rem; }
    
    .hero-title { font-family: var(--font-display); font-size: clamp(36px, 5vw, 64px); font-weight: 800; line-height: 1.0; letter-spacing: -2px; }
    .hero-meta { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; font-size: 12px; color: var(--text-muted); padding-top: 1.5rem; border-top: 1px solid var(--border); }
    .hero-featured { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; display: block; text-decoration: none; color: inherit; }
    .hero-featured-img { height: 200px; background: linear-gradient(135deg, #0d1f0a 0%, #1a3a0f 40%, #0a2a1a 100%); display: flex; align-items: center; justify-content: center; position: relative; }
    .hero-featured-body { padding: 1.4rem; }

    .section-header { display: flex; align-items: center; justify-content: space-between; padding: 2rem 0 1.2rem; border-bottom: 1px solid var(--border); }
    .section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--text-muted); }

    .comparatif-hero { display: grid; grid-template-columns: 1fr 320px; border-bottom: 1px solid var(--border); width: 100%; }
    .comparatif-main { padding: 2rem 2.5rem 2rem 0; border-right: 1px solid var(--border); }
    .comparatif-sidebar { padding: 2rem 0 2rem 2rem; }

    /* NEWSLETTER WIDGET FIX */
    .newsletter-widget { border: 1px solid var(--accent); border-radius: 8px; padding: 1.4rem; background: var(--accent-dim); width: 100%; max-width: 100%; }
    .newsletter-input { width: 100%; background: var(--bg); border: 1px solid var(--border); color: var(--text); padding: 10px; border-radius: 4px; margin-bottom: 8px; display: block; }
    .newsletter-btn { width: 100%; background: var(--accent); color: var(--accent-text); font-weight: 700; padding: 10px; border-radius: 4px; border: none; cursor: pointer; text-align: center; }

    .articles-grid { display: grid; grid-template-columns: repeat(3, 1fr); border-bottom: 1px solid var(--border); width: 100%; }
    .article-card { padding: 1.8rem; border-right: 1px solid var(--border); text-decoration: none; color: inherit; display: block; }
    .article-card:last-child { border-right: none; }

    .tools-strip { display: grid; grid-template-columns: repeat(4, 1fr); border-bottom: 1px solid var(--border); }
    .tool-card { padding: 1.4rem; border-right: 1px solid var(--border); text-decoration: none; color: inherit; display: flex; gap: 12px; }

    /* RESPONSIVE MOBILE FIX */
    @media (max-width: 900px) {
      .hero, .comparatif-hero, .articles-grid, .tools-strip { grid-template-columns: 1fr; }
      .hero-left, .comparatif-main, .article-card, .tool-card { border-right: none; padding-right: 0; padding-left: 0; border-bottom: 1px solid var(--border); }
      .comparatif-sidebar { padding: 2rem 0; }
    }
  </style>

  <div class="home-page">
    <div class="ticker">
      <div class="ticker-inner">
        <span>Nouveau — ChatGPT 5 disponible pour les entreprises</span><span>▸</span>
        <span>HubSpot intègre l'IA en 2026</span><span>▸</span>
        <span>Make.com vs Zapier</span><span>▸</span>
      </div>
    </div>

    <div class="wrap">
      <div class="hero">
        <div class="hero-left">
          <h1 class="hero-title">Les meilleurs outils <em>IA</em> pour votre entreprise</h1>
          <div class="hero-meta">
            <span>+120 outils analysés</span><span>•</span><span>100% indépendant</span>
          </div>
        </div>
        <div>
          {featured && (
            <a href={`/articles/${featured.slug}`} class="hero-featured">
              <div class="hero-featured-img">⚡</div>
              <div class="hero-featured-body">
                <h2 style="font-size:18px;">{featured.data.title}</h2>
              </div>
            </a>
          )}
        </div>
      </div>

      <div class="comparatif-hero">
        <div class="comparatif-main">
          <h2 style="font-size:28px;">Meilleur outil IA de rédaction PME</h2>
          <p style="color:var(--text-muted); margin: 1rem 0;">Notre sélection des 5 meilleurs outils de rédaction IA.</p>
          </div>
        
        <div class="comparatif-sidebar">
          <form id="newsletter-form" action="https://2224bad4.sibforms.com/serve/MUIFAA5FZ9wsz8jYxQoLCDh0LwleB1JzinLPJ8-XdB2OVm1lXNjNpuVAZxqsMhUxpLQzP4qmL8FdgRRwFog-CWPz4rAQJspvW9Vumzyfg4PvOaNHtUe7pPeOEChXfHsSn58QNgN1bJruhL1EgT5UjU1ub9wi4KPai9kOQOfii2viH8r9IM2YY3c2bdF5kfXolnpmvlJm5dTrmPAlnw==" method="POST" class="newsletter-widget">
            <div style="font-weight:800; margin-bottom:5px;">Un outil IA par semaine</div>
            <p style="font-size:12px; margin-bottom:10px;">La sélection des meilleurs outils chaque lundi.</p>
            <input type="email" name="EMAIL" class="newsletter-input" placeholder="votre@email.fr" required />
            <button type="submit" class="newsletter-btn">Je m'abonne</button>
            <input type="text" name="email_address_check" value="" style="display:none;">
            <input type="hidden" name="locale" value="fr">
          </form>
        </div>
      </div>

      <div class="section-header">
        <span class="section-title">Derniers articles</span>
      </div>

      <div class="articles-grid">
        {recent.map(a => (
          <a href={`/articles/${a.slug}`} class="article-card">
            <h3 style="font-size:16px;">{a.data.title}</h3>
            <p style="font-size:13px; color:var(--text-muted);">{a.data.readTime}</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const form = document.getElementById('newsletter-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button');
      btn.innerText = "PATIENTEZ...";
      btn.disabled = true;
      try {
        await fetch(form.action, { method: 'POST', body: new FormData(form), mode: 'no-cors' });
        btn.innerText = "MERCI !";
        btn.style.background = "#fff";
        btn.style.color = "#000";
        form.reset();
      } catch (err) {
        btn.innerText = "ERREUR";
        btn.disabled = false;
      }
    });
  }
</script>

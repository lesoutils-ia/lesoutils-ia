    .newsletter-btn { width: 100%; background: var(--accent); color: var(--accent-text); font-family: var(--font-display); font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 10px; border-radius: 4px; border: none; cursor: pointer; display: block; text-align: center; }
    .articles-grid { display: grid; grid-template-columns: repeat(3, 1fr); border-bottom: 1px solid var(--border); }
    @media (max-width: 900px) { .articles-grid { grid-template-columns: 1fr; } }
    .article-card { padding: 1.8rem; border-right: 1px solid var(--border); transition: background .15s; display: block; text-decoration: none; color: inherit; }
    .article-card:last-child { border-right: none; }
    .article-card:hover { background: var(--bg3); }
    .article-cat { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
    .article-title { font-family: var(--font-body); font-size: 16px; font-weight: 700; line-height: 1.4; letter-spacing: 0px; margin-bottom: 8px; }
    .article-excerpt { font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 1.2rem; }
    .article-footer { display: flex; align-items: center; justify-content: space-between; font-size: 11px; color: var(--text-muted); }
    .article-read { color: var(--accent); font-weight: 500; }
    .article-read::after { content: ' →'; }
    .tools-strip { display: grid; grid-template-columns: repeat(4, 1fr); border-bottom: 1px solid var(--border); }
    @media (max-width: 860px) { .tools-strip { grid-template-columns: repeat(2, 1fr); } }
    .tool-card { padding: 1.4rem 1.6rem; border-right: 1px solid var(--border); display: flex; align-items: flex-start; gap: 12px; transition: background .15s; text-decoration: none; color: inherit; }
    .tool-card:last-child { border-right: none; }
    .tool-card:hover { background: var(--bg3); }
    .tool-icon { width: 38px; height: 38px; border-radius: 8px; background: var(--bg3); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 800; font-size: 17px; color: var(--accent); flex-shrink: 0; }
    .tool-name { font-family: var(--font-body); font-size: 13px; font-weight: 700; margin-bottom: 3px; }
    .tool-desc { font-size: 11px; color: var(--text-muted); line-height: 1.4; }
    .tool-score { margin-top: 5px; font-size: 11px; color: var(--accent); font-weight: 500; }
    .bottom-banner { padding: 3.5rem 0; display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; border-bottom: 1px solid var(--border); }
    .banner-title { font-family: var(--font-display); font-size: clamp(22px, 3vw, 40px); font-weight: 800; letter-spacing: -1.5px; line-height: 1.1; }
    .banner-title span { color: var(--accent); }
    .banner-actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .btn-primary { background: var(--accent); color: var(--accent-text); font-family: var(--font-display); font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 13px 24px; border-radius: 4px; border: none; cursor: pointer; display: inline-block; text-decoration: none; }
    .btn-outline { background: transparent; color: var(--text); font-family: var(--font-display); font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; padding: 13px 24px; border-radius: 4px; border: 1px solid var(--border-strong); cursor: pointer; display: inline-block; text-decoration: none; }

        /* SECTION SEO */
    .seo-section { padding: 3.5rem 0; border-bottom: 1px solid var(--border); }
    
    .section-label { 
      font-family: var(--font-display); font-size: 11px; font-weight: 700; 
      letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); 
      margin-bottom: 1rem; 
    }

    .page-title { 
      font-family: var(--font-display); font-weight: 800; letter-spacing: -1px; 
      color: var(--text); 
    }

    .page-desc p { 
      font-size: 14px; color: var(--text-mid); line-height: 1.8; 
    }

    .guide-intro-grid { 
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 2.5rem; 
    }

    .step-card { 
      background: var(--bg3); border: 1px solid var(--border); 
      padding: 1.8rem; border-radius: 8px; transition: border-color 0.2s;
    }
    
    .step-card:hover { border-color: var(--border-strong); }

    .step-number { 
      display: block; font-family: var(--font-display); font-size: 24px; 
      font-weight: 800; color: var(--accent); margin-bottom: 1rem; opacity: 0.5; 
    }

    @media (max-width: 860px) { 
      .guide-intro-grid { grid-template-columns: 1fr; gap: 1.5rem; } 
    }


  </style>


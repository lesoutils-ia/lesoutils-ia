---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const featured = sorted.find(a => a.data.featured) || sorted[0];
const recent = sorted.filter(a => a.slug !== featured?.slug).slice(0, 3);
---

<BaseLayout 
  title="Les Outils IA : Le Média n°1 sur l'IA pour PME & Entreprises"
  description="Boostez la productivité de votre entreprise en 2026. Comparatifs indépendants, tests d'outils IA, guides pratiques et actualités pour maîtriser l'IA au bureau."
>
  <style>
    * { box-sizing: border-box; }
    .home-page { padding-top: 56px; overflow-x: hidden; width: 100%; }
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; width: 100%; }
    
    /* TICKER */
    .ticker { background: var(--accent); color: var(--accent-text); font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 7px 0; overflow: hidden; white-space: nowrap; }
    .ticker-inner { display: inline-block; animation: ticker 30s linear infinite; }
    .ticker-inner span { margin-right: 4rem; }
    @keyframes ticker { from { transform: translateX(0) } to { transform: translateX(-50%) } }

    /* HERO */
    .hero { padding: 3rem 0; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; border-bottom: 1px solid var(--border); }
    .hero-left { padding-right: 3rem; border-right: 1px solid var(--border); display: flex; flex-direction: column; gap: 2rem; }
    .hero-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); }
    .hero-title { font-family: var(--font-display); font-size: clamp(32px, 5vw, 64px); font-weight: 800; line-height: 1.1; letter-spacing: -2px; }
    .hero-desc { font-size: 18px; color: var(--text-muted); line-height: 1.6; max-width: 500px; }
    
    .featured-card { text-decoration: none; color: inherit; display: block; }
    .featured-img { width: 100%; aspect-ratio: 16/9; background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 1.5rem; overflow: hidden; }
    .featured-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
    .featured-card:hover img { transform: scale(1.03); }
    .featured-title { font-family: var(--font-display); font-size: 28px; font-weight: 800; line-height: 1.2; margin-bottom: 1rem; }
    
    /* RECENT */
    .recent-grid { padding: 3rem 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; border-bottom: 1px solid var(--border); }
    .recent-card { text-decoration: none; color: inherit; }
    .recent-cat { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.8rem; }
    .recent-title { font-size: 17px; font-weight: 700; line-height: 1.4; margin-bottom: 0.5rem; }
    
    /* TOOLS STRIP */
    .tools-strip { display: grid; grid-template-columns: repeat(4, 1fr); border-bottom: 1px solid var(--border); }
    .tool-card { padding: 1.4rem 1.6rem; border-right: 1px solid var(--border); display: flex; align-items: flex-start; gap: 12px; transition: background .15s; text-decoration: none; color: inherit; }
    .tool-card:last-child { border-right: none; }
    .tool-card:hover { background: var(--bg2); }
    .tool-icon { width: 32px; height: 32px; background: var(--bg3); border-radius: 6px; border: 1px solid var(--border); flex-shrink: 0; }
    .tool-name { font-weight: 700; font-size: 14px; margin-bottom: 2px; }
    .tool-tag { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }

    /* NEWSLETTER BOX */
    .newsletter-box { background: var(--accent); color: var(--accent-text); padding: 2rem; border-radius: 12px; margin-top: auto; }
    .newsletter-title { font-family: var(--font-display); font-size: 20px; font-weight: 800; margin-bottom: 0.5rem; }
    .newsletter-form { display: flex; gap: 10px; margin-top: 1.2rem; }
    .newsletter-input { flex: 1; background: rgba(0,0,0,0.1); border: 1px solid rgba(0,0,0,0.1); padding: 12px 16px; border-radius: 6px; font-size: 14px; outline: none; }
    .btn-dark { background: #000; color: #fff; border: none; padding: 0 20px; border-radius: 6px; font-weight: 700; font-size: 12px; text-transform: uppercase; cursor: pointer; }

    /* NOUVELLE SECTION EXPERTISE (FIN DE PAGE) */
    .expert-section { padding: 4rem 0; border-bottom: 1px solid var(--border); }
    .section-label { font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; }
    .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2.5rem; margin: 2rem 0 4rem; }
    .info-card { background: var(--bg3); border: 1px solid var(--border); padding: 2rem; border-radius: 12px; }
    .info-card h3 { font-family: var(--font-display); font-size: 18px; font-weight: 800; margin-bottom: 1rem; color: #fff; }
    .info-card p { font-size: 14px; color: var(--text-muted); line-height: 1.7; }
    .faq-simple-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 2rem; }
    .faq-q { font-family: var(--font-body); font-size: 15px; font-weight: 700; color: var(--accent); margin-bottom: 0.5rem; }
    .faq-a { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

    /* BOTTOM BANNER */
    .bottom-banner { padding: 3.5rem 0; display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; border-bottom: 1px solid var(--border); }
    .banner-title { font-family: var(--font-display); font-size: 28px; font-weight: 800; max-width: 400px; }
    .banner-title span { color: var(--accent); }
    .btn-primary { background: var(--accent); color: var(--accent-text); text-decoration: none; padding: 12px 24px; border-radius: 6px; font-weight: 700; font-size: 14px; }
    .btn-outline { border: 1px solid var(--border); color: #fff; text-decoration: none; padding: 12px 24px; border-radius: 6px; font-weight: 700; font-size: 14px; }

    @media (max-width: 860px) {
      .hero { grid-template-columns: 1fr; }
      .hero-left { border-right: none; padding-right: 0; border-bottom: 1px solid var(--border); padding-bottom: 2rem; }
      .recent-grid { grid-template-columns: 1fr; }
      .tools-strip { grid-template-columns: 1fr 1fr; }
      .faq-simple-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="home-page">
    <div class="ticker">
      <div class="ticker-inner">
        <span>• 100% INDÉPENDANT</span><span>• TESTS RÉELS</span><span>• SOLUTIONS PME</span><span>• IA GÉNÉRATIVE</span>
        <span>• 100% INDÉPENDANT</span><span>• TESTS RÉELS</span><span>• SOLUTIONS PME</span><span>• IA GÉNÉRATIVE</span>
      </div>
    </div>

    <div class="wrap">
      <section class="hero">
        <div class="hero-left">
          <div>
            <div class="hero-label">Média IA Indépendant</div>
            <h1 class="hero-title">L'IA au service de votre <span style="color:var(--accent)">productivité.</span></h1>
            <p class="hero-desc">Nous testons les meilleurs outils d'intelligence artificielle pour transformer votre manière de travailler en 2026.</p>
          </div>
          
          <div class="newsletter-box">
            <div class="newsletter-title">La dose hebdo d'IA</div>
            <p style="font-size: 13px; opacity: 0.9;">Rejoignez 4,500+ décideurs. Pas de spam, juste du concret.</p>
            <form class="newsletter-form" id="newsletter-form" action="https://formspree.io/f/mqakpwwp" method="POST">
              <input type="email" name="email" class="newsletter-input" placeholder="votre@email.com" required>
              <button type="submit" class="btn-dark">OK</button>
            </form>
          </div>
        </div>

        <div class="hero-right">
          {featured && (
            <a href={`/articles/${featured.slug}`} class="featured-card">
              <div class="featured-img">
                <img src={featured.data.image} alt={featured.data.title} />
              </div>
              <div class="hero-label" style="margin-bottom: 0.5rem;">À la une</div>
              <h2 class="featured-title">{featured.data.title}</h2>
              <p class="hero-desc" style="font-size: 15px;">{featured.data.description}</p>
            </a>
          )}
        </div>
      </section>

      <section class="recent-grid">
        {recent.map(post => (
          <a href={`/articles/${post.slug}`} class="recent-card">
            <div class="recent-cat">{post.data.category}</div>
            <h3 class="recent-title">{post.data.title}</h3>
            <p style="font-size: 13px; color: var(--text-muted); line-height: 1.5;">{post.data.description}</p>
          </a>
        ))}
      </section>

      <section class="tools-strip">
        <a href="/comparatifs/crm" class="tool-card">
          <div class="tool-icon"></div>
          <div><div class="tool-name">HubSpot</div><div class="tool-tag">CRM IA</div></div>
        </a>
        <a href="/comparatifs/automatisation" class="tool-card">
          <div class="tool-icon"></div>
          <div><div class="tool-name">Make.com</div><div class="tool-tag">Workflow</div></div>
        </a>
        <a href="/comparatifs/chatgpt-alternatives" class="tool-card">
          <div class="tool-icon"></div>
          <div><div class="tool-name">Claude 3.5</div><div class="tool-tag">LLM Pro</div></div>
        </a>
        <a href="/comparatifs/email-marketing" class="tool-card">
          <div class="tool-icon"></div>
          <div><div class="tool-name">Brevo</div><div class="tool-tag">Marketing</div></div>
        </a>
      </section>

      <section class="expert-section">
        <div class="section-label">Pourquoi nous faire confiance ?</div>
        <h2 style="font-family: var(--font-display); font-size: clamp(24px, 4vw, 36px); font-weight: 800; letter-spacing: -1px; margin-bottom: 2rem;">
          L'IA pour les entreprises : <span style="color:var(--accent)">Au-delà de la hype.</span>
        </h2>
        
        <div class="info-grid">
          <div class="info-card">
            <h3>Tests en conditions réelles</h3>
            <p>Contrairement aux sites qui copient les fiches techniques, nous intégrons chaque outil dans nos propres workflows de PME française. Nous mesurons le gain de temps réel et la facilité d'adoption par les équipes non-techniques.</p>
          </div>
          <div class="info-card">
            <h3>Indépendance Editoriale</h3>
            <p>Nos comparatifs sont basés sur des critères objectifs : conformité RGPD, service client francophone, et surtout, le rapport coût/bénéfice pour une structure de 1 à 50 salariés. Si un outil est décevant, nous le disons.</p>
          </div>
          <div class="info-card">
            <h3>Mise à jour 2026</h3>
            <p>Le marché de l'IA change chaque semaine. Nos guides de formation et nos comparatifs de CRM ou d'automatisations sont révisés mensuellement pour refléter les dernières versions des modèles comme ChatGPT, Claude ou Mistral.</p>
          </div>
        </div>

        <div class="section-label">Foire aux questions stratégique</div>
        <div class="faq-simple-grid">
          <div>
            <div class="faq-q">Quel est le meilleur outil IA pour débuter en entreprise ?</div>
            <div class="faq-a">Pour 90% des PME, la porte d'entrée idéale reste un assistant de rédaction et d'analyse comme ChatGPT Plus ou Claude Pro, combiné à un outil d'automatisation simple comme Make pour lier vos emails à votre CRM.</div>
          </div>
          <div>
            <div class="faq-q">Comment financer la montée en compétences de mes salariés ?</div>
            <div class="faq-a">En 2026, de nombreux dispositifs comme le FNE-Formation ou le CPF permettent de couvrir jusqu'à 100% des frais pédagogiques pour les formations liées à l'IA générative et à la transformation numérique.</div>
          </div>
          <div>
            <div class="faq-q">L'IA est-elle compatible avec le RGPD ?</div>
            <div class="faq-a">Oui, à condition de choisir les bonnes versions. Nous privilégions dans nos guides les solutions qui offrent des options de stockage de données en Europe et qui garantissent que vos données d'entreprise ne servent pas à entraîner les modèles publics.</div>
          </div>
          <div>
            <div class="faq-q">Quel budget prévoir pour l'IA en PME ?</div>
            <div class="faq-a">Une "stack" IA performante pour un collaborateur coûte environ 50€ à 150€ par mois (abonnements outils + crédits API). Le gain de productivité mesuré dépasse généralement les 20% dès le deuxième mois.</div>
          </div>
        </div>
      </section>

      <div class="bottom-banner">
        <h2 class="banner-title">Votre outil IA absent de <span>notre classement ?</span></h2>
        <div class="banner-actions">
          <a href="/contact" class="btn-primary">Soumettre un outil</a>
          <a href="/contact" class="btn-outline">Devenir partenaire</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const form = document.getElementById('newsletter-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button');
      btn.innerText = "PATIENTEZ...";
      btn.disabled = true;
      try {
        await fetch(form.action, { method: 'POST', body: new FormData(form), mode: 'no-cors' });
        btn.innerText = "MERCI !";
        btn.style.backgroundColor = "#fff";
        btn.style.color = "#000";
        form.reset();
      } catch (err) {
        btn.innerText = "ERREUR";
        btn.disabled = false;
      }
    });
  }
</script>

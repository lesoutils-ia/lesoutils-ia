---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — lesoutils-ia.fr">
  <style>
    .page { padding-top: 56px; }
    .page-wrap { max-width: 800px; margin: 0 auto; padding: 3rem 1.5rem; }
    .page-title { font-family: var(--font-display); font-size: clamp(28px, 4vw, 42px); font-weight: 700; line-height: 1.3; margin-bottom: 0.8rem; }
    .page-subtitle { font-size: 16px; color: var(--text-muted); margin-bottom: 3rem; line-height: 1.7; }
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 3rem; }
    @media (max-width: 600px) { .contact-grid { grid-template-columns: 1fr; } }
    .contact-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1.6rem; }
    .contact-card-icon { font-size: 24px; margin-bottom: 0.8rem; }
    .contact-card-title { font-family: var(--font-display); font-size: 15px; font-weight: 700; margin-bottom: 0.4rem; }
    .contact-card-desc { font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem; }
    .contact-card-link { color: var(--accent); font-size: 14px; font-weight: 500; text-decoration: underline; text-underline-offset: 3px; word-break: break-all; }
    .contact-note { background: var(--accent-dim); border: 1px solid var(--accent); border-radius: 8px; padding: 1.4rem; font-size: 14px; color: var(--text-mid); line-height: 1.7; }
    .contact-note strong { color: var(--text); }
  </style>

  <div class="page">
    <div class="wrap">
      <div class="page-wrap">
        <h1 class="page-title">Contact</h1>
        <p class="page-subtitle">Une question, un partenariat, un outil à nous soumettre ? On vous répond sous 48h.</p>

        <div class="contact-grid">
          <div class="contact-card">
            <div class="contact-card-icon">✉️</div>
            <div class="contact-card-title">Contact général</div>
            <div class="contact-card-desc">Questions, suggestions, corrections d'articles.</div>
            <a href="mailto:lesoutilsia1@gmail.com" class="contact-card-link">lesoutilsia1@gmail.com</a>
          </div>
          <div class="contact-card">
            <div class="contact-card-icon">🤝</div>
            <div class="contact-card-title">Partenariats</div>
            <div class="contact-card-desc">Classements sponsorisés, affiliation, vente de liens.</div>
            <a href="mailto:lesoutilsia1@gmail.com" class="contact-card-link">lesoutilsia1@gmail.com</a>
          </div>
          <div class="contact-card">
            <div class="contact-card-icon">🛠️</div>
            <div class="contact-card-title">Soumettre un outil</div>
            <div class="contact-card-desc">Vous avez un outil IA à faire tester et référencer.</div>
            <a href="mailto:lesoutilsia1@gmail.com" class="contact-card-link">lesoutilsia1@gmail.com</a>
          </div>
          <div class="contact-card">
            <div class="contact-card-icon">📝</div>
            <div class="contact-card-title">Presse</div>
            <div class="contact-card-desc">Demandes d'interviews, citations, collaboration éditoriale.</div>
            <a href="mailto:lesoutilsia1@gmail.com" class="contact-card-link">lesoutilsia1@gmail.com</a>
          </div>
        </div>

        <div class="contact-note">
          <strong>Délai de réponse :</strong> Nous répondons à tous les emails sous 48h ouvrées. Pour les demandes de partenariat, merci de préciser le nom de votre outil ou service et votre budget mensuel estimé.
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

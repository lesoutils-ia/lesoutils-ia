---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  author: string;
  authorInitials: string;
  publishDate: string;
  updateDate?: string;
  readTime: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, category, tags, author, authorInitials, updateDate, publishDate, readTime, headings } = Astro.props;
const pageTitle = title;
const h2headings = headings.filter(h => h.depth === 2 || h.depth === 3);
const categorySlug = category.toLowerCase().replace(/ /g, '-').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
---

<BaseLayout title={pageTitle} description={description}>
  <div class="progress-bar" id="progress"></div>
  
  <div class="article-page">
    <div class="wrap">
      <div class="breadcrumb">
        <a href="/">Accueil</a> › <a href={`/${categorySlug}`}>{category}</a> › <span>{title.substring(0, 30)}...</span>
      </div>

      <div class="article-header">
        <div class="article-cat-row">
          <span class="article-cat">{category}</span>
          {tags.map(tag => <span class="article-tag">{tag}</span>)}
        </div>
        <h1 class="article-title">{title}</h1>
        <p class="article-subtitle">{description}</p>
        <div class="article-meta-row">
  <div class="meta-author">
    <div class="author-avatar">{authorInitials}</div>
    {author}
  </div>
  <span class="meta-date">
    {new Date(publishDate).toLocaleDateString('fr-FR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })}
  </span>
  <span>{readTime} de lecture</span>
</div>

      </div>

      <div class="article-body-wrap">
        <article class="article-content">
          <slot />
        </article>

        <aside class="article-sidebar">
          <div class="toc-widget">
            <div class="toc-title">Sommaire</div>
            <ul class="toc-list">
              {h2headings.map(h => (
                <li class={h.depth === 3 ? 'toc-h3' : ''}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </div>

          <div class="sidebar-sponsored">
             <div class="sidebar-sponsored-label">Partenaires</div>
             <a href="https://jasper.ai" target="_blank" class="sidebar-tool-item">Jasper AI</a>
             <a href="https://www.make.com" target="_blank" class="sidebar-tool-item">Make.com</a>
          </div>

          <form 
            id="newsletter-form" 
            action="https://2224bad4.sibforms.com/serve/MUIFAA5FZ9wsz8jYxQoLCDh0LwleB1JzinLPJ8-XdB2OVm1lXNjNpuVAZxqsMhUxpLQzP4qmL8FdgRRwFog-CWPz4rAQJspvW9Vumzyfg4PvOaNHtUe7pPeOEChXfHsSn58QNgN1bJruhL1EgT5UjU1ub9wi4KPai9kOQOfii2viH8r9IM2YY3c2bdF5kfXolnpmvlJm5dTrmPAlnw==" 
            method="POST"
            class="newsletter-widget"
          >
            <div class="newsletter-widget-title">Un outil IA par semaine</div>
            <p>La sélection des meilleurs outils IA chaque lundi.</p>
            <input type="email" name="EMAIL" class="newsletter-input" placeholder="votre@email.fr" required />
            <button type="submit" class="newsletter-btn">Je m'abonne</button>
            <input type="text" name="email_address_check" value="" style="display:none;">
            <input type="hidden" name="locale" value="fr">
          </form>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .progress-bar { position: fixed; top: 56px; left: 0; height: 2px; background: var(--accent); z-index: 99; width: 0%; transition: width .1s linear; }
  .article-page { padding-top: 56px; }
  .breadcrumb { padding: 1.2rem 0 0; display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-muted); }
  .article-header { padding: 2rem 0 0; max-width: 760px; }
  .article-cat-row { display: flex; gap: 8px; margin-bottom: 1rem; }
  .article-cat { font-size: 10px; font-weight: 700; color: var(--accent); background: var(--accent-dim); padding: 4px 10px; border-radius: 3px; text-transform: uppercase; }
  .article-tag { font-size: 10px; color: var(--text-muted); padding: 4px 10px; border-radius: 3px; border: 1px solid var(--border); text-transform: uppercase; }
  .article-title { font-size: clamp(26px, 4vw, 44px); font-weight: 700; margin-bottom: 1.2rem; }
  .article-subtitle { font-size: 16px; color: var(--text-mid); line-height: 1.6; margin-bottom: 1.5rem; }
  .article-meta-row { display: flex; align-items: center; gap: 1.2rem; font-size: 12px; color: var(--text-muted); border-top: 1px solid var(--border); padding-top: 1rem; }
  .author-avatar { width: 26px; height: 26px; border-radius: 50%; background: var(--accent-dim); display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--accent); margin-right: 8px; }
  .meta-author { display: flex; align-items: center; }
  .article-body-wrap { padding: 2rem 0; display: grid; grid-template-columns: 1fr 300px; gap: 4rem; }
  @media (max-width: 900px) { .article-body-wrap { grid-template-columns: 1fr; } }
  .toc-widget { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1.4rem; margin-bottom: 1.2rem; }
  .toc-title { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1rem; }
  .toc-list { list-style: none; padding: 0; }
  .toc-list li a { display: block; font-size: 13px; color: var(--text-muted); padding: 5px 0; text-decoration: none; }
  .toc-list li a.active { color: var(--accent); font-weight: 700; }
  .article-sidebar { position: sticky; top: 80px; }
  .sidebar-sponsored { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1.4rem; margin-bottom: 1.2rem; }
  .sidebar-sponsored-label { font-size: 9px; font-weight: 700; text-transform: uppercase; color: var(--text-muted); margin-bottom: 10px; }
  .sidebar-tool-item { display: block; padding: 8px 0; font-size: 13px; text-decoration: none; color: var(--text); border-bottom: 1px solid var(--border); }
  .newsletter-widget { border: 1px solid var(--accent); border-radius: 8px; padding: 1.4rem; background: var(--accent-dim); }
  .newsletter-widget-title { font-size: 15px; font-weight: 800; margin-bottom: 5px; }
  .newsletter-input { width: 100%; padding: 10px; border-radius: 4px; border: 1px solid var(--border); margin-bottom: 8px; background: var(--bg); color: var(--text); }
  .newsletter-btn { width: 100%; background: var(--accent); color: var(--accent-text); font-weight: 700; padding: 10px; border-radius: 4px; border: none; cursor: pointer; }
</style>

<script is:inline>
  // Sommaire et Barre de progression
  window.addEventListener('scroll', () => {
    const progress = document.getElementById('progress');
    if (progress) {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      progress.style.width = (window.scrollY / h * 100) + '%';
    }
    const links = document.querySelectorAll('.toc-list a');
    const sections = document.querySelectorAll('article [id]');
    let current = '';
    sections.forEach(s => {
      if (window.scrollY >= s.offsetTop - 120) current = s.id;
    });
    links.forEach(l => {
      l.classList.toggle('active', l.getAttribute('href') === '#' + current);
    });
  });

  // Newsletter
  const form = document.getElementById('newsletter-form');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button');
    btn.innerText = "ENVOI...";
    btn.disabled = true;
    try {
      await fetch(form.action, { method: 'POST', body: new FormData(form), mode: 'no-cors' });
      btn.innerText = "MERCI !";
      btn.style.background = "white";
      btn.style.color = "black";
      form.reset();
    } catch (err) {
      btn.innerText = "ERREUR";
      btn.disabled = false;
    }
  });
</script>

---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  author: string;
  authorInitials: string;
  publishDate: string;
  updateDate?: string;
  readTime: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, category, tags, author, authorInitials, updateDate, publishDate, readTime, headings } = Astro.props;
const pageTitle = `${title} — lesoutils-ia.fr`;
const h2headings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={pageTitle} description={description}>
  <style>
    .progress-bar { position: fixed; top: 56px; left: 0; height: 2px; background: var(--accent); z-index: 99; width: 0%; transition: width .1s linear; }
    .article-page { padding-top: 56px; }
    .breadcrumb { padding: 1.2rem 0 0; display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-muted); flex-wrap: wrap; }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb-sep { opacity: .4; }
    .article-header { padding: 2rem 0 0; display: grid; grid-template-columns: 1fr 300px; gap: 4rem; align-items: start; }
    @media (max-width: 900px) { .article-header { grid-template-columns: 1fr; gap: 2rem; } .article-toc { display: none; } }
    .article-cat-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 1rem; }
    .article-cat { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 4px 10px; border-radius: 3px; }
    .article-tag { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); padding: 4px 10px; border-radius: 3px; border: 1px solid var(--border); }
    .article-title { font-family: var(--font-display); font-size: clamp(22px, 3vw, 38px); font-weight: 700; line-height: 1.3; letter-spacing: -0.3px; margin-bottom: 1rem; overflow: visible; }
    .article-subtitle { font-size: 16px; color: var(--text-mid); line-height: 1.65; font-weight: 300; margin-bottom: 1.5rem; }
    .article-meta-row { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; padding: 1rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); font-size: 12px; color: var(--text-muted); }
    .meta-author { display: flex; align-items: center; gap: 8px; }
    .author-avatar { width: 26px; height: 26px; border-radius: 50%; background: var(--accent-dim); border: 1px solid var(--accent); display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; color: var(--accent); font-family: var(--font-display); }
    .meta-sep { opacity: .3; }
    .meta-updated { color: var(--accent); }
    .article-toc { position: sticky; top: 72px; }
    .toc-widget { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1.4rem; }
    .toc-title { font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1rem; }
    .toc-list { list-style: none; display: flex; flex-direction: column; gap: 1px; }
    .toc-list li a { display: block; font-size: 13px; color: var(--text-muted); padding: 6px 10px; border-radius: 4px; border-left: 2px solid transparent; transition: all .15s; line-height: 1.4; }
    .toc-list li a:hover { color: var(--text); background: var(--bg); }
    .toc-list li a.active { color: var(--accent); border-left-color: var(--accent); background: var(--accent-dim); }
    .toc-list li.toc-h3 a { padding-left: 20px; font-size: 12px; }
    .article-body-wrap { padding: 2.5rem 0; display: grid; grid-template-columns: 1fr 300px; gap: 4rem; align-items: start; }
    @media (max-width: 900px) { .article-body-wrap { grid-template-columns: 1fr; gap: 2.5rem; } }
    .article-content h2 { font-family: var(--font-display); font-size: clamp(20px, 2.5vw, 26px); font-weight: 700; letter-spacing: -0.3px; line-height: 1.3; margin: 3.5rem 0 1rem; padding-top: 2.5rem; border-top: 1px solid var(--border); }
    .article-content h2:first-child { margin-top: 0; padding-top: 0; border-top: none; }
    .article-content h3 { font-family: var(--font-display); font-size: 18px; font-weight: 700; letter-spacing: -0.2px; margin: 2.5rem 0 0.7rem; }
    .article-content p { font-size: 15px; line-height: 1.8; color: var(--text-mid); margin-bottom: 1.8rem; }
    .article-content strong { color: var(--text); font-weight: 500; }
    .article-content ul, .article-content ol { margin: 0.8rem 0 1.8rem 1rem; padding-left: 1rem; color: var(--text-mid); }
    .article-content li { font-size: 15px; line-height: 1.8; margin-bottom: 6px; }
    .article-content a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
    .article-content blockquote { background: var(--bg3); border-left: 3px solid var(--accent); padding: 1rem 1.4rem; margin: 2rem 0; border-radius: 0 6px 6px 0; font-size: 14px; color: var(--text-mid); }
    .article-content code { background: var(--bg3); border: 1px solid var(--border); padding: 2px 7px; border-radius: 4px; font-size: 13px; color: var(--accent); font-family: monospace; }
    .article-content pre { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1.2rem; margin: 2rem 0; overflow-x: auto; }
    .article-content pre code { background: none; border: none; padding: 0; color: var(--text-mid); font-size: 13px; }
    .article-sidebar { position: sticky; top: 72px; }
    @media (max-width: 900px) { .article-sidebar { position: static; } }
    .sidebar-sponsored { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 1.4rem; margin-bottom: 1.2rem; }
    .sidebar-sponsored-label { font-size: 9px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1rem; text-align: center; }
    .sidebar-tool-item { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border); }
    .sidebar-tool-item:last-child { border-bottom: none; padding-bottom: 0; }
    .sidebar-tool-icon { width: 34px; height: 34px; border-radius: 7px; background: var(--bg); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 800; font-size: 14px; color: var(--accent); flex-shrink: 0; }
    .sidebar-tool-name { font-family: var(--font-display); font-size: 13px; font-weight: 700; margin-bottom: 1px; }
    .sidebar-tool-desc { font-size: 11px; color: var(--text-muted); }
    .sidebar-tool-cta { margin-left: auto; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); border: 1px solid var(--accent); padding: 4px 9px; border-radius: 3px; white-space: nowrap; flex-shrink: 0; transition: all .15s; }
    .sidebar-tool-item:hover .sidebar-tool-cta { background: var(--accent); color: var(--accent-text); }
    .newsletter-widget { border: 1px solid var(--accent); border-radius: 8px; padding: 1.4rem; background: var(--accent-dim); }
    .newsletter-widget-title { font-family: var(--font-display); font-size: 15px; font-weight: 800; margin-bottom: 5px; }
    .newsletter-widget p { font-size: 12px; color: var(--text-muted); margin-bottom: 1rem; }
    .newsletter-input { width: 100%; background: var(--bg); border: 1px solid var(--border); color: var(--text); font-family: var(--font-body); font-size: 13px; padding: 10px 14px; border-radius: 4px; outline: none; margin-bottom: 8px; display: block; }
    .newsletter-input::placeholder { color: var(--text-muted); }
    .newsletter-input:focus { border-color: var(--accent); }
    .newsletter-btn { width: 100%; background: var(--accent); color: var(--accent-text); font-family: var(--font-display); font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 10px; border-radius: 4px; border: none; cursor: pointer; }
    .related-section { border-top: 1px solid var(--border); padding: 2.5rem 0; }
    .related-title { font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1.5rem; }
    .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
    @media (max-width: 860px) { .related-grid { grid-template-columns: 1fr; } .related-card { border-right: none !important; border-bottom: 1px solid var(--border); } .related-card:last-child { border-bottom: none; } }
    .related-card { padding: 1.4rem 1.8rem; border-right: 1px solid var(--border); display: block; transition: background .15s; }
    .related-card:last-child { border-right: none; }
    .related-card:hover { background: var(--bg3); }
    .related-cat { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 7px; }
    .related-card-title { font-family: var(--font-display); font-size: 15px; font-weight: 700; line-height: 1.3; margin-bottom: 8px; }
    .related-arrow { font-size: 12px; color: var(--accent); }
  </style>

  <div class="progress-bar" id="progress"></div>
  <div class="article-page">
    <div class="wrap">
      <div class="breadcrumb">
        <a href="/">Accueil</a>
        <span class="breadcrumb-sep">›</span>
        <a href={`/${category.toLowerCase().replace(/ /g, '-')}`}>{category}</a>
        <span class="breadcrumb-sep">›</span>
        <span style="color:var(--text-mid);">{title.substring(0, 45)}…</span>
      </div>

      <div class="article-header fade-up">
        <div>
          <div class="article-cat-row">
            <span class="article-cat">{category}</span>
            {tags.map(tag => <span class="article-tag">{tag}</span>)}
          </div>
          <h1 class="article-title">{title}</h1>
          <p class="article-subtitle">{description}</p>
          <div class="article-meta-row">
            <div class="meta-author">
              <div class="author-avatar">{authorInitials}</div>
              <span>{author}</span>
            </div>
            <span class="meta-sep">·</span>
            <span>{readTime} de lecture</span>
            <span class="meta-sep">·</span>
            <span class="meta-updated">↻ Mis à jour {updateDate || publishDate}</span>
          </div>
        </div>
        <div class="article-toc">
          <div class="toc-widget">
            <div class="toc-title">Sommaire</div>
            <ul class="toc-list">
              {h2headings.map(h => (
                <li class={h.depth === 3 ? 'toc-h3' : ''}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="article-body-wrap">
        <article class="article-content">
          <slot />
        </article>
        <aside class="article-sidebar">
          <div class="sidebar-sponsored">
            <div class="sidebar-sponsored-label">Partenaires</div>
            <div class="sidebar-tool-item">
              <div class="sidebar-tool-icon">J</div>
              <div><div class="sidebar-tool-name">Jasper AI</div><div class="sidebar-tool-desc">Essai gratuit 7 jours</div></div>
              <span class="sidebar-tool-cta">Essayer</span>
            </div>
            <div class="sidebar-tool-item">
              <div class="sidebar-tool-icon">H</div>
              <div><div class="sidebar-tool-name">HubSpot</div><div class="sidebar-tool-desc">CRM gratuit</div></div>
              <span class="sidebar-tool-cta">Essayer</span>
            </div>
            <div class="sidebar-tool-item">
              <div class="sidebar-tool-icon">M</div>
              <div><div class="sidebar-tool-name">Make.com</div><div class="sidebar-tool-desc">Plan gratuit disponible</div></div>
              <span class="sidebar-tool-cta">Essayer</span>
            </div>
          </div>
          <div class="newsletter-widget" id="newsletter">
            <div class="newsletter-widget-title">Un outil IA par semaine</div>
            <p>La sélection des meilleurs outils IA chaque lundi.</p>
            <input type="email" class="newsletter-input" placeholder="votre@email.fr" />
            <button class="newsletter-btn">Je m'abonne</button>
          </div>
        </aside>
      </div>

      <div class="related-section">
        <div class="related-title">Articles similaires</div>
        <div class="related-grid">
          <a href="/articles/resumer-pdf-chatgpt" class="related-card">
            <div class="related-cat">Guide ChatGPT</div>
            <div class="related-card-title">Résumer un PDF avec ChatGPT — guide complet</div>
            <div class="related-arrow">Lire →</div>
          </a>
          <a href="/articles/meilleurs-prompts-chatgpt" class="related-card">
            <div class="related-cat">Guide ChatGPT</div>
            <div class="related-card-title">Les meilleurs prompts ChatGPT pour les professionnels</div>
            <div class="related-arrow">Lire →</div>
          </a>
          <a href="/articles/formation-ia-cpf" class="related-card">
            <div class="related-cat">Formation</div>
            <div class="related-card-title">Formation IA finançable CPF — le guide complet 2026</div>
            <div class="related-arrow">Lire →</div>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const progress = document.getElementById('progress');
  if (progress) {
    window.addEventListener('scroll', () => {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      progress.style.width = (window.scrollY / h * 100) + '%';
    });
  }
  const tocLinks = document.querySelectorAll('.toc-list a');
  const headings = document.querySelectorAll('article [id]');
  window.addEventListener('scroll', () => {
    let current = '';
    headings.forEach(h => {
      if (window.scrollY >= (h as HTMLElement).offsetTop - 100) current = h.id;
    });
    tocLinks.forEach(a => {
      a.classList.toggle('active', a.getAttribute('href') === '#' + current);
    });
  });
</script>
